{% doc %}
  Renders the slide-in cart drawer with AJAX cart management.
{% enddoc %}

<div class="vcd-overlay" id="vcd-overlay" aria-hidden="true"></div>

<div class="vcd" id="vcd" role="dialog" aria-modal="true" aria-label="Cart" aria-hidden="true">
  <div class="vcd__header">
    <div class="vcd__title">
      Cart
      <span class="vcd__count" id="vcd-count">0</span>
    </div>
    <button class="vcd__close" id="vcd-close" aria-label="Close cart">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="vcd__body" id="vcd-body">
    <div class="vcd__loading" id="vcd-loading">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19aaf8" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></path></svg>
    </div>
    <div class="vcd__items" id="vcd-items"></div>
    <div class="vcd__empty" id="vcd-empty" style="display:none;">
      <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="#c7d0de" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <p>Your cart is empty</p>
    </div>
  </div>

  <div class="vcd__footer" id="vcd-footer" style="display:none;">
    <div class="vcd__total-row">
      <span class="vcd__total-label">Total</span>
      <span class="vcd__total-price" id="vcd-total">0 kr</span>
    </div>
    <a href="{{ routes.cart_url }}" class="vcd__checkout-btn" id="vcd-checkout-btn">
      Proceed to checkout
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <p class="vcd__note">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      Complete installation included &bull; Klarna &amp; Länsförsäkringar Finans
    </p>
  </div>
</div>

{% stylesheet %}
  .vcd-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 600;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.28s, visibility 0.28s;
  }
  .vcd-overlay.is-open { opacity: 1; visibility: visible; }

  .vcd {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(420px, 100vw);
    background: #fff;
    z-index: 601;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(.4,0,.2,1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.14);
  }
  .vcd.is-open { transform: translateX(0); }

  .vcd__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #e6e8ef;
    flex-shrink: 0;
  }
  .vcd__title {
    font-size: 18px;
    font-weight: 700;
    color: #224466;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .vcd__count {
    background: #19aaf8;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    min-width: 22px;
    height: 22px;
    border-radius: 11px;
    padding: 0 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vcd__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    color: #5b6474;
    transition: background 0.15s;
  }
  .vcd__close:hover { background: #f1f5f9; color: #224466; }

  .vcd__body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 24px;
  }
  .vcd__loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 0;
  }
  .vcd__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 64px 0;
    color: #a0aab4;
    font-size: 15px;
  }

  .vcd__item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid #f0f2f7;
  }
  .vcd__item:last-child { border-bottom: none; }
  .vcd__item-img {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    background: #f5f9fc;
    object-fit: contain;
    padding: 6px;
    border: 1px solid #e6e8ef;
    display: block;
  }
  .vcd__item-img-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    background: #f5f9fc;
    border: 1px solid #e6e8ef;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c7d0de;
  }
  .vcd__item-details { display: flex; flex-direction: column; gap: 6px; }
  .vcd__item-title {
    font-size: 14px;
    font-weight: 600;
    color: #224466;
    line-height: 1.3;
  }
  .vcd__item-price-label {
    font-size: 11px;
    color: #5b6474;
  }
  .vcd__item-prices { display: flex; align-items: center; gap: 8px; }
  .vcd__item-compare {
    font-size: 12px;
    color: #a0aab4;
    text-decoration: line-through;
  }
  .vcd__item-price {
    font-size: 15px;
    font-weight: 700;
    color: #19aaf8;
  }
  .vcd__item-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }
  .vcd__qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1.5px solid #e6e8ef;
    border-radius: 8px;
    overflow: hidden;
  }
  .vcd__qty-btn {
    background: none;
    border: none;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #5b6474;
    font-size: 16px;
    transition: background 0.12s, color 0.12s;
  }
  .vcd__qty-btn:hover { background: #f1f5f9; color: #224466; }
  .vcd__qty-num {
    font-size: 14px;
    font-weight: 600;
    color: #224466;
    min-width: 28px;
    text-align: center;
  }
  .vcd__item-remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    color: #a0aab4;
    transition: background 0.12s, color 0.12s;
  }
  .vcd__item-remove:hover { background: #fef2f2; color: #e53e3e; }

  .vcd__footer {
    padding: 20px 24px;
    border-top: 1px solid #e6e8ef;
    flex-shrink: 0;
    background: #fff;
  }
  .vcd__total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }
  .vcd__total-label {
    font-size: 15px;
    font-weight: 600;
    color: #5b6474;
  }
  .vcd__total-price {
    font-size: 20px;
    font-weight: 800;
    color: #224466;
  }
  .vcd__checkout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 15px 20px;
    background: #19aaf8;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    transition: background 0.15s;
    margin-bottom: 12px;
  }
  .vcd__checkout-btn:hover { background: #224466; }
  .vcd__note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12px;
    color: #5b6474;
    text-align: center;
  }

  /* ── Toast ── */
  .vcd-toast {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-80px);
    background: #16a34a;
    color: #fff;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 700;
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    transition: transform 0.35s cubic-bezier(.4,0,.2,1), opacity 0.35s;
    opacity: 0;
    white-space: nowrap;
    max-width: calc(100vw - 40px);
  }
  .vcd-toast--visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
{% endstylesheet %}

<script>
(function() {
  var drawer = document.getElementById('vcd');
  var overlay = document.getElementById('vcd-overlay');
  var closeBtn = document.getElementById('vcd-close');
  var itemsEl = document.getElementById('vcd-items');
  var emptyEl = document.getElementById('vcd-empty');
  var loadingEl = document.getElementById('vcd-loading');
  var footerEl = document.getElementById('vcd-footer');
  var totalEl = document.getElementById('vcd-total');
  var countEl = document.getElementById('vcd-count');

  function updateBadge(count) {
    var headerCount = document.getElementById('varma-cart-count');
    if (headerCount) {
      headerCount.textContent = count;
      headerCount.classList.toggle('is-hidden', count < 1);
    }
    if (countEl) countEl.textContent = count;
  }

  function formatMoney(cents) {
    return Math.round(cents / 100).toLocaleString('sv-SE') + ' kr';
  }

  function renderCart(cart) {
    loadingEl.style.display = 'none';
    updateBadge(cart.item_count);

    if (!cart.item_count) {
      itemsEl.innerHTML = '';
      emptyEl.style.display = 'flex';
      footerEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none';
    footerEl.style.display = 'block';
    totalEl.textContent = formatMoney(cart.total_price);

    itemsEl.innerHTML = cart.items.map(function(item) {
      var img = item.image
        ? '<img class="vcd__item-img" src="' + item.image + '" alt="' + item.product_title + '" loading="lazy">'
        : '<div class="vcd__item-img-placeholder"><svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg></div>';
      var compare = item.original_price > item.final_price
        ? '<span class="vcd__item-compare">' + formatMoney(item.original_price) + '</span>' : '';
      return '<div class="vcd__item" data-key="' + item.key + '">'
        + img
        + '<div class="vcd__item-details">'
          + '<div class="vcd__item-title">' + item.product_title + '</div>'
          + '<div class="vcd__item-price-label">Price after ROT deduction</div>'
          + '<div class="vcd__item-prices">' + compare
            + '<span class="vcd__item-price">' + formatMoney(item.final_price) + '</span></div>'
          + '<div class="vcd__item-bottom">'
            + '<div class="vcd__qty">'
              + '<button class="vcd__qty-btn" data-qty-change="-1" data-key="' + item.key + '" data-qty="' + item.quantity + '">−</button>'
              + '<span class="vcd__qty-num">' + item.quantity + '</span>'
              + '<button class="vcd__qty-btn" data-qty-change="1" data-key="' + item.key + '" data-qty="' + item.quantity + '">+</button>'
            + '</div>'
            + '<button class="vcd__item-remove" data-remove="' + item.key + '" aria-label="Remove">'
              + '<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>'
            + '</button>'
          + '</div>'
        + '</div>'
      + '</div>';
    }).join('');

    itemsEl.querySelectorAll('[data-qty-change]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var qty = parseInt(btn.getAttribute('data-qty')) + parseInt(btn.getAttribute('data-qty-change'));
        changeQty(btn.getAttribute('data-key'), Math.max(0, qty));
      });
    });
    itemsEl.querySelectorAll('[data-remove]').forEach(function(btn) {
      btn.addEventListener('click', function() { changeQty(btn.getAttribute('data-remove'), 0); });
    });
  }

  function fetchCart() {
    loadingEl.style.display = 'flex';
    itemsEl.innerHTML = '';
    emptyEl.style.display = 'none';
    footerEl.style.display = 'none';
    fetch('/cart.js').then(function(r) { return r.json(); }).then(renderCart)
      .catch(function() { loadingEl.style.display = 'none'; });
  }

  function changeQty(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function(r) { return r.json(); }).then(renderCart);
  }

  function openDrawer() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    fetchCart();
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });

  // Wire header cart button — runs after DOM is ready since this script is at bottom of body
  var cartBtn = document.getElementById('varma-cart-btn');
  if (cartBtn) cartBtn.addEventListener('click', openDrawer);

  // Toast notification
  function showToast(title) {
    var existing = document.getElementById('vcd-toast');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.id = 'vcd-toast';
    toast.className = 'vcd-toast';
    toast.innerHTML = '<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>'
      + '<span><strong>' + title + '</strong> added to cart</span>';
    document.body.appendChild(toast);
    requestAnimationFrame(function() { toast.classList.add('vcd-toast--visible'); });
    setTimeout(function() {
      toast.classList.remove('vcd-toast--visible');
      setTimeout(function() { toast.remove(); }, 400);
    }, 3000);
  }

  // AJAX add-to-cart (product page + shop grid buttons)
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-ajax-atc]');
    if (!btn) return;
    e.preventDefault();
    var variantId = btn.getAttribute('data-variant-id');
    if (!variantId) return;
    btn.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    }).then(function(r) { return r.json(); })
      .then(function(item) {
        showToast(item.product_title || 'Product');
        openDrawer();
        btn.disabled = false;
      })
      .catch(function() { btn.disabled = false; });
  });

  // Global API for other scripts
  window.varmaCartDrawer = { open: openDrawer, close: closeDrawer, refresh: fetchCart };
})();
</script>
