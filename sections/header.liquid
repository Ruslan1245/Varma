<header class="varma-header">
  <div class="varma-header__inner">
    <a href="{{ routes.root_url }}" class="varma-header__logo" aria-label="{{ shop.name }}">
      <span class="varma-logo-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
      </span>
      <span class="varma-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
    </a>

    <nav class="varma-header__nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="varma-header__nav-link {% if link.active %}varma-header__nav-link--active{% endif %}">
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    <div class="varma-header__actions">
      <a href="{{ routes.cart_url }}" class="varma-header__cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="varma-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="varma-header__cta">
        {{ section.settings.cta_text | default: 'Få offert' }}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .varma-header {
    background: #fff;
    border-bottom: 1px solid #e6e8ef;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .varma-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .varma-header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .varma-logo-icon {
    width: 38px;
    height: 38px;
    background: #19aaf8;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .varma-logo-text {
    font-size: 20px;
    font-weight: 700;
    color: #224466;
    letter-spacing: -0.02em;
  }
  .varma-header__nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }
  .varma-header__nav-link {
    padding: 6px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #2a2f3d;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .varma-header__nav-link:hover,
  .varma-header__nav-link--active {
    color: #19aaf8;
    background: #e8f6fe;
  }
  .varma-header__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .varma-header__cart {
    position: relative;
    display: flex;
    align-items: center;
    color: #2a2f3d;
    text-decoration: none;
    padding: 8px;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .varma-header__cart:hover { background: #F1F5F9; }
  .varma-header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #19aaf8;
    color: white;
    font-size: 10px;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .varma-header__cta {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #224466;
    color: white;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.15s;
  }
  .varma-header__cta:hover { background: #1876b5; }
  @media (max-width: 900px) {
    .varma-header__nav { display: none; }
    .varma-header__inner { gap: 16px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Varma"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Få offert"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
