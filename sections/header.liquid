<header class="varma-header full-width">
  <div class="varma-header__inner">

    <button class="varma-header__burger" aria-label="Open menu" aria-expanded="false" aria-controls="varma-mobile-nav">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <a href="{{ routes.root_url }}" class="varma-header__logo" aria-label="{{ shop.name }}">
      <span class="varma-logo-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
      </span>
      <span class="varma-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
    </a>

    <nav class="varma-header__nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        {% if link.links != blank %}
          <div class="varma-nav-item varma-nav-item--dropdown">
            <button class="varma-header__nav-link varma-header__nav-link--parent" aria-expanded="false" aria-haspopup="true">
              {{ link.title }}
              <svg class="varma-nav-chevron" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="varma-nav-dropdown {% if link.links.size > 5 %}varma-nav-dropdown--wide{% endif %}">
              {% if link.links.size > 5 %}
                <div class="varma-nav-dropdown__header">
                  <div class="varma-nav-dropdown__header-text">
                    <span class="varma-nav-dropdown__header-label">{{ 'sections.header.dropdown_label' | t }}</span>
                    <span class="varma-nav-dropdown__header-title">{{ 'sections.header.dropdown_title' | t }}</span>
                  </div>
                  <span class="varma-nav-dropdown__header-badge">{{ link.links.size }} {{ 'sections.header.dropdown_cities' | t }}</span>
                </div>
                <div class="varma-nav-dropdown__grid">
                  {% for child in link.links %}
                    <a href="{{ child.url }}" class="varma-nav-dropdown__item {% if child.active %}varma-nav-dropdown__item--active{% endif %}">
                      <span class="varma-nav-dropdown__item-icon" aria-hidden="true">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      </span>
                      <span class="varma-nav-dropdown__item-title">{{ child.title }}</span>
                    </a>
                  {% endfor %}
                </div>
              {% else %}
                {% for child in link.links %}
                  <a href="{{ child.url }}" class="varma-nav-dropdown__item {% if child.active %}varma-nav-dropdown__item--active{% endif %}">
                    <span class="varma-nav-dropdown__item-icon" aria-hidden="true">
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </span>
                    <span>
                      <span class="varma-nav-dropdown__item-title">{{ child.title }}</span>
                    </span>
                  </a>
                {% endfor %}
              {% endif %}
            </div>
          </div>
        {% else %}
          <a href="{{ link.url }}" class="varma-header__nav-link {% if link.active %}varma-header__nav-link--active{% endif %}">
            {{ link.title }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="varma-header__actions">
      <button type="button" class="varma-header__cart" id="varma-cart-btn" aria-label="Cart">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="varma-header__cart-count{% unless cart.item_count > 0 %} is-hidden{% endunless %}" id="varma-cart-count">{{ cart.item_count }}</span>
      </button>
      <a href="/pages/fa-offert" class="varma-header__cta">
        {{ section.settings.cta_text | default: 'Get a quote' }}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</header>

<div class="varma-mobile-nav" id="varma-mobile-nav" aria-hidden="true">
  <div class="varma-mobile-nav__header">
    <a href="{{ routes.root_url }}" class="varma-header__logo">
      <span class="varma-logo-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
      </span>
      <span class="varma-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
    </a>
    <button class="varma-mobile-nav__close" aria-label="Close menu">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav class="varma-mobile-nav__list">
    {% for link in section.settings.menu.links %}
      {% if link.links != blank %}
        <details class="varma-mobile-nav__group">
          <summary class="varma-mobile-nav__group-title">
            {{ link.title }}
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="varma-mobile-nav__children">
            {% for child in link.links %}
              <a href="{{ child.url }}" class="varma-mobile-nav__child">{{ child.title }}</a>
            {% endfor %}
          </div>
        </details>
      {% else %}
        <a href="{{ link.url }}" class="varma-mobile-nav__link {% if link.active %}varma-mobile-nav__link--active{% endif %}">{{ link.title }}</a>
      {% endif %}
    {% endfor %}
    <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="varma-header__cta" style="margin-top:16px;justify-content:center;">
      {{ section.settings.cta_text | default: 'Get a quote' }}
    </a>
  </nav>
</div>
<div class="varma-mobile-nav__backdrop" aria-hidden="true"></div>

{% stylesheet %}
  .varma-header {
    background: #fff;
    border-bottom: 1px solid #e6e8ef;
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .varma-header__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .varma-header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .varma-logo-icon {
    width: 38px;
    height: 38px;
    background: #19aaf8;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .varma-logo-text {
    font-size: 20px;
    font-weight: 700;
    color: #224466;
    letter-spacing: -0.02em;
  }

  /* Desktop nav */
  .varma-header__nav {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  .varma-header__nav-link {
    padding: 6px 11px;
    font-size: 15px;
    font-weight: 500;
    color: #2a2f3d;
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .varma-header__nav-link:hover,
  .varma-header__nav-link--active { color: #19aaf8; background: #e8f6fe; }

  /* Dropdown parent button */
  .varma-nav-item { position: relative; }
  .varma-header__nav-link--parent {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .varma-nav-chevron { transition: transform 0.2s; flex-shrink: 0; }
  .varma-nav-item--dropdown:hover .varma-nav-chevron,
  .varma-nav-item--dropdown.is-open .varma-nav-chevron { transform: rotate(180deg); }

  /* Dropdown panel */
  .varma-nav-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #fff;
    border: 1px solid #e6e8ef;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(34,68,102,0.12), 0 2px 8px rgba(34,68,102,0.06);
    padding: 8px;
    min-width: 240px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 300;
  }
  .varma-nav-item--dropdown:hover .varma-nav-dropdown,
  .varma-nav-item--dropdown.is-open .varma-nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .varma-nav-dropdown--wide {
    min-width: 440px;
  }
  .varma-nav-dropdown__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  .varma-nav-dropdown__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
    color: #2a2f3d;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.12s, color 0.12s;
  }
  .varma-nav-dropdown__item:hover,
  .varma-nav-dropdown__item--active { background: #e8f6fe; color: #19aaf8; }
  .varma-nav-dropdown__item-icon {
    width: 30px;
    height: 30px;
    background: #e8f6fe;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #19aaf8;
  }
  .varma-nav-dropdown__item:hover .varma-nav-dropdown__item-icon { background: #c7e8fc; }
  .varma-nav-dropdown__item-title { font-weight: 600; }
  .varma-nav-dropdown__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 12px 10px;
    border-bottom: 1px solid #e6e8ef;
    margin-bottom: 6px;
  }
  .varma-nav-dropdown__header-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .varma-nav-dropdown__header-label {
    font-size: 11px;
    font-weight: 700;
    color: #19aaf8;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .varma-nav-dropdown__header-title {
    font-size: 13px;
    font-weight: 600;
    color: #224466;
  }
  .varma-nav-dropdown__header-badge {
    font-size: 12px;
    font-weight: 600;
    color: #224466;
    background: #e8f6fe;
    border-radius: 20px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  /* Actions */
  .varma-header__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .varma-header__cart {
    position: relative;
    display: flex;
    align-items: center;
    color: #2a2f3d;
    text-decoration: none;
    padding: 8px;
    border-radius: 8px;
    transition: background 0.15s;
    background: none;
    border: none;
    cursor: pointer;
  }
  .varma-header__cart:hover { background: #f1f5f9; }
  .varma-header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #19aaf8;
    color: white;
    font-size: 10px;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .varma-header__cart-count.is-hidden { display: none; }
  .varma-header__cta {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #222299;
    color: white;
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .varma-header__cta:hover { background: rgba(34,34,153,0.9); }
  .varma-header__burger {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    color: #2a2f3d;
    transition: background 0.15s;
    flex-shrink: 0;
    order: -1;
  }
  .varma-header__burger:hover { background: #f1f5f9; }

  /* Mobile nav overlay */
  .varma-mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 88vw);
    background: #fff;
    z-index: 500;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(.4,0,.2,1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 32px rgba(0,0,0,0.12);
    overflow-y: auto;
    grid-row: 1;
  }
  .varma-mobile-nav.is-open { transform: translateX(0); }
  .varma-mobile-nav__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 499;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.28s, visibility 0.28s;
    grid-row: 1;
  }
  .varma-mobile-nav__backdrop.is-open { opacity: 1; visibility: visible; }
  .varma-mobile-nav__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e6e8ef;
    flex-shrink: 0;
  }
  .varma-mobile-nav__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    color: #2a2f3d;
    transition: background 0.15s;
  }
  .varma-mobile-nav__close:hover { background: #f1f5f9; }
  .varma-mobile-nav__list {
    padding: 12px 16px 32px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .varma-mobile-nav__link {
    padding: 11px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #2a2f3d;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.12s;
  }
  .varma-mobile-nav__link:hover,
  .varma-mobile-nav__link--active { background: #e8f6fe; color: #19aaf8; }
  .varma-mobile-nav__group { border-radius: 8px; overflow: hidden; }
  .varma-mobile-nav__group-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 12px;
    font-size: 15px;
    font-weight: 500;
    color: #2a2f3d;
    cursor: pointer;
    list-style: none;
    border-radius: 8px;
    transition: background 0.12s;
  }
  .varma-mobile-nav__group-title::-webkit-details-marker { display: none; }
  .varma-mobile-nav__group-title:hover { background: #f1f5f9; }
  .varma-mobile-nav__group[open] .varma-mobile-nav__group-title { background: #e8f6fe; color: #19aaf8; }
  .varma-mobile-nav__children {
    padding: 4px 0 4px 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .varma-mobile-nav__child {
    padding: 9px 12px;
    font-size: 14px;
    font-weight: 500;
    color: #5b6474;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
  }
  .varma-mobile-nav__child:hover { background: #f1f5f9; color: #224466; }

  @media (max-width: 960px) {
    .varma-header__nav { display: none; }
    .varma-header__burger { display: flex; }
    /* Logo stretches to fill space between burger and actions */
    .varma-header__logo { flex: 1; }
  }
  @media (max-width: 600px) {
    .varma-header__inner { padding: 0 16px; gap: 8px; height: 60px; }
    .varma-header__cta { padding: 8px 12px; font-size: 13px; }
    .varma-header__cta svg { display: none; }
    .varma-logo-text { font-size: 18px; }
  }
  @media (max-width: 360px) {
    .varma-header__cta { display: none; }
  }
{% endstylesheet %}

{% javascript %}
  /* Open SA Request a Quote widget (class prefix: grfq-) */
  window.openSAQuote = function() {
    // grfq-quote-widget is the inner clickable div (not the -container wrapper)
    var el = document.querySelector('.grfq-quote-widget') ||
             document.querySelector('[class*="grfq-quote-widget-tab"]') ||
             document.querySelector('[class*="grfq-quote-widget"] button') ||
             document.querySelector('[class*="grfq-quote-widget"]');
    if (el) { el.click(); return; }
    window.location.href = '/pages/request-for-quote';
  };

  (function() {
    var burger = document.querySelector('.varma-header__burger');
    var mobileNav = document.getElementById('varma-mobile-nav');
    var backdrop = document.querySelector('.varma-mobile-nav__backdrop');
    var closeBtn = document.querySelector('.varma-mobile-nav__close');

    function openNav() {
      mobileNav.classList.add('is-open');
      backdrop.classList.add('is-open');
      mobileNav.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeNav() {
      mobileNav.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      mobileNav.setAttribute('aria-hidden', 'true');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (burger) burger.addEventListener('click', openNav);
    if (closeBtn) closeBtn.addEventListener('click', closeNav);
    if (backdrop) backdrop.addEventListener('click', closeNav);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeNav();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Varma"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Get a quote"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ]
}
{% endschema %}
