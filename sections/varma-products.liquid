<section class="v-products full-width">
  <div class="v-products__container">
    <div class="v-products__header">
      <div>
        {% if section.settings.label != blank %}
          <p class="v-label">{{ section.settings.label }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="v-products__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="v-products__desc">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      {% if section.settings.view_all_text != blank %}
        {% assign view_all_href = section.settings.view_all_url | default: section.settings.collection.url | default: '/collections/all' %}
        {% assign products_total = section.settings.collection.products_count %}
        <a href="{{ view_all_href }}" class="v-products__view-all">
          {{ section.settings.view_all_text }}{% if products_total > 0 %} {{ products_total }} {{ 'sections.products.view_all_products' | t }}{% endif %}
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="v-products__grid">
      {% assign featured_collection = section.settings.collection %}
      {% if featured_collection != blank %}
        {% for product in featured_collection.products limit: section.settings.products_count %}
          <div class="v-products__card">
            <a href="{{ product.url }}" class="v-products__card-link">
              <div class="v-products__card-image">
                {% if section.settings.badge_text != blank %}
                  <span class="v-products__badge">{{ section.settings.badge_text }}</span>
                {% endif %}
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'v-products__placeholder' }}
                {% endif %}
              </div>
              <div class="v-products__card-body">
                {% if product.type != blank %}
                  <p class="v-products__type">{{ product.type | upcase }}</p>
                {% endif %}
                <h3 class="v-products__title">{{ product.title }}</h3>
                {% if section.settings.price_label != blank %}
                  <p class="v-products__price-label">{{ section.settings.price_label }}</p>
                {% endif %}
              </div>
            </a>
            <div class="v-products__card-footer">
              <div class="v-products__prices">
                {% if product.compare_at_price > product.price %}
                  <span class="v-products__compare-price">{{ product.compare_at_price | money }}</span>
                {% endif %}
                <span class="v-products__price">{{ product.price | money }}</span>
              </div>
              <form action="{{ routes.cart_add_url }}" method="post">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="v-products__add-btn" {% unless product.available %}disabled{% endunless %}>
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                  {{ section.settings.add_to_cart_text | default: 'LГ¤gg till' }}
                </button>
              </form>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="v-products__card">
            <div class="v-products__card-link">
              <div class="v-products__card-image">
                {% if section.settings.badge_text != blank %}
                  <span class="v-products__badge">{{ section.settings.badge_text }}</span>
                {% endif %}
                {{ 'product-1' | placeholder_svg_tag: 'v-products__placeholder' }}
              </div>
              <div class="v-products__card-body">
                <p class="v-products__type">LUFT-LUFT VГ„RMEPUMP</p>
                <h3 class="v-products__title">Toshiba VГ¤rmepump {{ i }}</h3>
                <div class="v-products__pricing">
                  {% if section.settings.price_label != blank %}
                    <p class="v-products__price-label">{{ section.settings.price_label }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-products {
    padding: 80px 0;
    background: #f5f9fc;
  }
  .v-products__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .v-products__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .v-products__heading {
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 800;
    color: #224466;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .v-products__desc {
    font-size: 15px;
    color: #5b6474;
  }
  .v-products__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #19aaf8;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .v-products__view-all:hover { text-decoration: underline; }
  .v-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .v-products__card {
    background: white;
    border: 1px solid #e6e8ef;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .v-products__card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .v-products__card-image {
    position: relative;
    aspect-ratio: 1;
    background: #f5f9fc;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
  }
  .v-products__card-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .v-products__placeholder { width: 100%; height: 100%; }
  .v-products__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: white;
    border: 1px solid #e6e8ef;
    color: #2a2f3d;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 6px;
  }
  .v-products__card-body {
    padding: 16px;
    flex: 1;
  }
  .v-products__type {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #5b6474;
    margin-bottom: 6px;
  }
  .v-products__title {
    font-size: 16px;
    font-weight: 700;
    color: #224466;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .v-products__price-label {
    font-size: 12px;
    color: #5b6474;
    margin-bottom: 4px;
  }
  .v-products__prices {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .v-products__compare-price {
    font-size: 13px;
    color: #5b6474;
    text-decoration: line-through;
  }
  .v-products__price {
    font-size: 18px;
    font-weight: 800;
    color: #19aaf8;
  }
  .v-products__card-footer {
    padding: 12px 16px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .v-products__add-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #19aaf8;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 9px 14px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .v-products__add-btn:hover { background: #224466; }
  .v-products__add-btn:disabled {
    background: #c7e8fc;
    cursor: not-allowed;
  }
  @media (max-width: 900px) {
    .v-products__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .v-products__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "VARMA SHOP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "VГ¤rmepumpar med installation ingГҐr."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Auktoriserade installatГ¶rer, fast pris och 5 ГҐrs garanti вЂ“ fri leverans i hela Stockholm."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all link text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link URL"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Product badge text",
      "default": "INKL. INSTALLATION"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Price label",
      "default": "Pris efter ROT-avdrag"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Add to cart button text",
      "default": "LГ¤gg till"
    }
  ],
  "presets": [{ "name": "Varma Featured Products" }]
}
{% endschema %}
