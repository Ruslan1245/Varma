{%- paginate blog.articles by section.settings.posts_per_page -%}

<div class="vbl full-width">

  <div class="vbl__hero">
    <div class="vbl__container">
      <h1 class="vbl__heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.description != blank -%}
        <p class="vbl__intro">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="vbl__body">
    <div class="vbl__container">

      {%- if blog.articles_count > 0 -%}
        <div class="vbl__grid">
          {%- for article in blog.articles -%}
            <article class="vbl__card">
              {%- if article.image -%}
                <a href="{{ article.url }}" class="vbl__card-img-wrap" tabindex="-1" aria-hidden="true">
                  {{ article.image | image_url: width: 640 | image_tag: class: 'vbl__card-img', loading: 'lazy', alt: article.image.alt }}
                </a>
              {%- endif -%}
              <div class="vbl__card-body">
                <time class="vbl__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: '%Y-%m-%d' }}
                </time>
                <h2 class="vbl__card-title">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>
                <p class="vbl__card-excerpt">
                  {%- if article.excerpt != blank -%}
                    {{ article.excerpt | strip_html | truncatewords: 24 }}
                  {%- else -%}
                    {{ article.content | strip_html | truncatewords: 24 }}
                  {%- endif -%}
                </p>
                <a href="{{ article.url }}" class="vbl__card-link">{{ section.settings.read_more }} →</a>
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="vbl__pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}

      {%- else -%}
        <p class="vbl__empty">{{ section.settings.no_posts }}</p>
      {%- endif -%}

    </div>
  </div>

</div>

{%- endpaginate -%}

{% stylesheet %}
  .vbl__hero {
    background: #EFF4FF;
    padding: 48px 0 56px;
  }
  .vbl__container {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .vbl__heading {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    color: #0f1c3f;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .vbl__intro {
    font-size: 17px;
    color: #555;
    line-height: 1.6;
    max-width: 560px;
  }
  .vbl__body {
    padding: 64px 0 80px;
    background: #fff;
  }
  .vbl__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .vbl__card {
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.15s;
  }
  .vbl__card:hover {
    box-shadow: 0 6px 28px rgba(0,0,0,0.08);
  }
  .vbl__card-img-wrap {
    display: block;
    overflow: hidden;
    aspect-ratio: 16/9;
  }
  .vbl__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .vbl__card:hover .vbl__card-img {
    transform: scale(1.03);
  }
  .vbl__card-body {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .vbl__card-date {
    font-size: 13px;
    color: #999;
    margin-bottom: 10px;
    display: block;
  }
  .vbl__card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 12px;
  }
  .vbl__card-title a {
    color: #19aaf8;
    text-decoration: none;
  }
  .vbl__card-title a:hover {
    text-decoration: underline;
  }
  .vbl__card-excerpt {
    font-size: 14px;
    color: #666;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }
  .vbl__card-link {
    font-size: 14px;
    font-weight: 600;
    color: #19aaf8;
    text-decoration: none;
    align-self: flex-start;
  }
  .vbl__card-link:hover { text-decoration: underline; }
  .vbl__pagination {
    margin-top: 56px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  .vbl__pagination a,
  .vbl__pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border: 1px solid #dde3ed;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: #333;
    background: #fff;
    transition: border-color 0.15s;
  }
  .vbl__pagination a:hover { border-color: #19aaf8; color: #19aaf8; }
  .vbl__pagination .current { background: #19aaf8; border-color: #19aaf8; color: #fff; }
  .vbl__empty {
    font-size: 16px;
    color: #999;
    text-align: center;
    padding: 80px 0;
  }
  @media (max-width: 900px) {
    .vbl__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .vbl__hero { padding: 36px 0 40px; }
    .vbl__body { padding: 48px 0; }
    .vbl__container { padding: 0 20px; }
    .vbl__grid { grid-template-columns: 1fr; }
    .vbl__card-body { padding: 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog listing",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blog"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Advice, guides and insights about heat pumps in Stockholm."
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 9
    },
    {
      "type": "text",
      "id": "read_more",
      "label": "Read more text",
      "default": "Read more"
    },
    {
      "type": "text",
      "id": "no_posts",
      "label": "Empty state text",
      "default": "No posts yet. Check back soon."
    }
  ],
  "presets": [
    {
      "name": "Blog listing"
    }
  ]
}
{% endschema %}
