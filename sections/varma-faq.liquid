<section class="v-faq full-width">
  <div class="v-faq__container">
    <div class="v-faq__left">
      {% if section.settings.label != blank %}
        <p class="v-label">{{ section.settings.label }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="v-faq__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="v-faq__desc">{{ section.settings.description }}</p>
      {% endif %}

      {% if section.settings.contact_heading != blank %}
        <div class="v-faq__contact">
          <div class="v-faq__contact-header">
            <div class="v-faq__contact-icon" aria-hidden="true">
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
            </div>
            <div>
              <div class="v-faq__contact-title">{{ section.settings.contact_heading }}</div>
              <div class="v-faq__contact-sub">{{ section.settings.contact_subtext }}</div>
            </div>
          </div>
          <div class="v-faq__contact-actions">
            {% if section.settings.contact_cta_text != blank %}
              <a href="{{ section.settings.contact_cta_url }}" class="v-faq__contact-btn">
                {{ section.settings.contact_cta_text }}
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            {% endif %}
            {% if section.settings.contact_phone != blank %}
              <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}" class="v-faq__contact-phone">
                {{ section.settings.contact_phone }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="v-faq__right">
      {% for block in section.blocks %}
        <details class="v-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="v-faq__question">
            <span class="v-faq__question-num">0{{ forloop.index }}</span>
            <span>{{ block.settings.question }}</span>
            <span class="v-faq__icon" aria-hidden="true">
              <svg class="v-faq__icon-plus" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <svg class="v-faq__icon-minus" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <div class="v-faq__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-faq {
    padding: 80px 0;
    background: #f5f9fc;
  }
  .v-faq__container {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: start;
  }
  .v-faq__heading {
    font-size: clamp(26px, 2.5vw, 36px);
    font-weight: 800;
    color: #224466;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .v-faq__desc {
    font-size: 15px;
    color: #5b6474;
    line-height: 1.65;
    margin-bottom: 32px;
  }
  .v-faq__contact {
    background: white;
    border: 1px solid #e6e8ef;
    border-radius: 16px;
    padding: 24px;
  }
  .v-faq__contact-header {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
  }
  .v-faq__contact-icon {
    width: 40px;
    height: 40px;
    background: #e8f6fe;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-faq__contact-title {
    font-size: 15px;
    font-weight: 700;
    color: #224466;
    margin-bottom: 4px;
  }
  .v-faq__contact-sub {
    font-size: 13px;
    color: #5b6474;
    line-height: 1.5;
  }
  .v-faq__contact-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .v-faq__contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #19aaf8;
    color: white;
    text-decoration: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.15s;
  }
  .v-faq__contact-btn:hover { background: #0e8fd6; }
  .v-faq__contact-phone {
    font-size: 14px;
    font-weight: 600;
    color: #2a2f3d;
    text-decoration: none;
  }
  .v-faq__contact-phone:hover { color: #19aaf8; }
  .v-faq__item {
    background: white;
    border: 1px solid #e6e8ef;
    border-radius: 12px;
    margin-bottom: 10px;
    overflow: hidden;
  }
  .v-faq__item[open] {
    border-color: #19aaf8;
  }
  .v-faq__question {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    font-size: 15px;
    font-weight: 600;
    color: #224466;
    line-height: 1.4;
  }
  .v-faq__question::-webkit-details-marker { display: none; }
  .v-faq__question-num {
    font-size: 13px;
    color: #5b6474;
    font-weight: 500;
    flex-shrink: 0;
  }
  .v-faq__question span:nth-child(2) { flex: 1; }
  .v-faq__icon {
    flex-shrink: 0;
    color: #19aaf8;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .v-faq__icon-minus { display: none; }
  .v-faq__item[open] .v-faq__icon-plus { display: none; }
  .v-faq__item[open] .v-faq__icon-minus { display: block; }
  .v-faq__answer {
    padding: 0 24px 20px;
    font-size: 15px;
    color: #5b6474;
    line-height: 1.65;
    border-top: 1px solid #e6e8ef;
    padding-top: 16px;
  }
  @media (max-width: 900px) {
    .v-faq__container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
{% endstylesheet %}

<script src="{{ 'varma-faq.js' | asset_url }}" defer></script>


