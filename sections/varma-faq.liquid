<section class="v-faq">
  <div class="v-faq__container">
    <div class="v-faq__left">
      {% if section.settings.label != blank %}
        <p class="v-label">{{ section.settings.label }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="v-faq__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="v-faq__desc">{{ section.settings.description }}</p>
      {% endif %}

      {% if section.settings.contact_heading != blank %}
        <div class="v-faq__contact">
          <div class="v-faq__contact-header">
            <div class="v-faq__contact-icon" aria-hidden="true">
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#2563EB" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
            </div>
            <div>
              <div class="v-faq__contact-title">{{ section.settings.contact_heading }}</div>
              <div class="v-faq__contact-sub">{{ section.settings.contact_subtext }}</div>
            </div>
          </div>
          <div class="v-faq__contact-actions">
            {% if section.settings.contact_cta_text != blank %}
              <a href="{{ section.settings.contact_cta_url }}" class="v-faq__contact-btn">
                {{ section.settings.contact_cta_text }}
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            {% endif %}
            {% if section.settings.contact_phone != blank %}
              <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}" class="v-faq__contact-phone">
                {{ section.settings.contact_phone }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="v-faq__right">
      {% for block in section.blocks %}
        <details class="v-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="v-faq__question">
            <span class="v-faq__question-num">0{{ forloop.index }}</span>
            <span>{{ block.settings.question }}</span>
            <span class="v-faq__icon" aria-hidden="true">
              <svg class="v-faq__icon-plus" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <svg class="v-faq__icon-minus" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <div class="v-faq__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-faq {
    padding: 80px 0;
    background: #F8FAFC;
  }
  .v-faq__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: start;
  }
  .v-faq__heading {
    font-size: clamp(26px, 2.5vw, 36px);
    font-weight: 800;
    color: #0F172A;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .v-faq__desc {
    font-size: 15px;
    color: #475569;
    line-height: 1.65;
    margin-bottom: 32px;
  }
  .v-faq__contact {
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 24px;
  }
  .v-faq__contact-header {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
  }
  .v-faq__contact-icon {
    width: 40px;
    height: 40px;
    background: #EFF6FF;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-faq__contact-title {
    font-size: 15px;
    font-weight: 700;
    color: #0F172A;
    margin-bottom: 4px;
  }
  .v-faq__contact-sub {
    font-size: 13px;
    color: #64748B;
    line-height: 1.5;
  }
  .v-faq__contact-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .v-faq__contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #2563EB;
    color: white;
    text-decoration: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.15s;
  }
  .v-faq__contact-btn:hover { background: #1D4ED8; }
  .v-faq__contact-phone {
    font-size: 14px;
    font-weight: 600;
    color: #374151;
    text-decoration: none;
  }
  .v-faq__contact-phone:hover { color: #2563EB; }
  .v-faq__item {
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    margin-bottom: 10px;
    overflow: hidden;
  }
  .v-faq__item[open] {
    border-color: #BFDBFE;
  }
  .v-faq__question {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    font-size: 15px;
    font-weight: 600;
    color: #0F172A;
    line-height: 1.4;
  }
  .v-faq__question::-webkit-details-marker { display: none; }
  .v-faq__question-num {
    font-size: 13px;
    color: #94A3B8;
    font-weight: 500;
    flex-shrink: 0;
  }
  .v-faq__question span:nth-child(2) { flex: 1; }
  .v-faq__icon {
    flex-shrink: 0;
    color: #2563EB;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .v-faq__icon-minus { display: none; }
  .v-faq__item[open] .v-faq__icon-plus { display: none; }
  .v-faq__item[open] .v-faq__icon-minus { display: block; }
  .v-faq__answer {
    padding: 0 24px 20px;
    font-size: 15px;
    color: #475569;
    line-height: 1.65;
    border-top: 1px solid #E2E8F0;
    padding-top: 16px;
  }
  @media (max-width: 900px) {
    .v-faq__container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your question?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Your answer goes here."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "VANLIGA FRÅGOR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Svar för Stockholms villaägare."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Raka svar om pris, tidplan, garantier och ROT – från teamet som installerar i hela Storstockholm varje dag."
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact box heading",
      "default": "Har du fler frågor?"
    },
    {
      "type": "text",
      "id": "contact_subtext",
      "label": "Contact box subtext",
      "default": "Prata med en Varma-specialist — kostnadsfritt och utan förpliktelser."
    },
    {
      "type": "text",
      "id": "contact_cta_text",
      "label": "Contact CTA text",
      "default": "Boka kostnadsfritt besök"
    },
    {
      "type": "url",
      "id": "contact_cta_url",
      "label": "Contact CTA URL"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact phone",
      "default": "+46 8 123 456 789"
    }
  ],
  "presets": [
    {
      "name": "Varma FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "Vad kostar en värmepumpsinstallation i Stockholm?",
            "answer": "En komplett luftvärmepumpsinstallation för en typisk villa på 120–150 m² i Stockholm landar oftast på 85 000–140 000 kr inkl. utrustning och arbete. Bergvärme ligger högre, 180 000–280 000 kr, men ger betydligt större besparingar över tid. Varma lämnar fast pris efter ett kostnadsfritt hembesök."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Hur lång tid tar installationen?",
            "answer": "En luftvärmepump installeras normalt på 1–2 dagar. Bergvärme tar 3–5 dagar inklusive borrning. Vi planerar arbetet så att du störs så lite som möjligt."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Vilken garanti lämnar ni?",
            "answer": "Vi lämnar 10 års garanti på installationsarbetet och följer tillverkarens produktgaranti, vanligtvis 5–7 år. Alla våra installatörer är certifierade och F-gas-behöriga."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Hur snabbt rycker ni ut vid akuta ärenden?",
            "answer": "Vi har tekniker stationerade i hela Storstockholm och garanterar utryckning inom 2 timmar dygnet runt, alla dagar om året – även helger och röda dagar."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Finns det bidrag eller avdrag för värmepumpar i Sverige?",
            "answer": "Ja! Du kan nyttja ROT-avdraget som ger 30% skattereduktion på arbetskostnaden. Vi hanterar ROT-ansökan åt dig direkt och du betalar bara det reducerade beloppet."
          }
        }
      ]
    }
  ]
}
{% endschema %}
