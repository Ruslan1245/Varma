<div class="ann-bar full-width">
  <div class="ann-bar__inner">
    <div class="ann-bar__left">
      <span class="ann-bar__item">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        {{ section.settings.hours }}
      </span>
      <span class="ann-bar__sep" aria-hidden="true">·</span>
      <span class="ann-bar__item">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {{ section.settings.certification }}
      </span>
    </div>
    <div class="ann-bar__right">
      <span class="ann-bar__item">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
        {{ section.settings.phone }}
      </span>
      <span class="ann-bar__item ann-bar__avail">
        <span class="ann-bar__dot" aria-hidden="true"></span>
        {{ section.settings.availability }}
      </span>
    </div>
  </div>
</div>

{% stylesheet %}
  .ann-bar {
    background-color: #19aaf8;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 0;
  }
  .ann-bar__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .ann-bar__left,
  .ann-bar__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .ann-bar__item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ann-bar__sep {
    opacity: 0.5;
  }
  .ann-bar__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #4ADE80;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .ann-bar__sep { display: none; }
    .ann-bar__left { gap: 10px; font-size: 12px; }
    .ann-bar__right { gap: 10px; font-size: 12px; }
  }
  @media (max-width: 425px) {
    .ann-bar { padding: 6px 0; }
    .ann-bar__inner { padding: 0 12px; gap: 4px; }
    .ann-bar__left { gap: 5px; font-size: 9.5px; }
    .ann-bar__right { gap: 5px; font-size: 9.5px; }
    .ann-bar__avail { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "hours",
      "label": "Hours",
      "default": "Mon–Fri 07–18 · Sat 09–14"
    },
    {
      "type": "text",
      "id": "certification",
      "label": "Certification text",
      "default": "Authorized installer · 10-year warranty"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "08-12 34 56 78"
    },
    {
      "type": "text",
      "id": "availability",
      "label": "Availability text",
      "default": "Technicians available now"
    }
  ]
}
{% endschema %}
