<div class="vcp full-width">

  <!-- HERO -->
  <div class="vcp__hero">
    {% if section.settings.bg_image %}
      {{ section.settings.bg_image | image_url: width: 2560 | image_tag: class: 'vcp__hero-img', loading: 'eager', fetchpriority: 'high', alt: '' }}
    {% else %}
      <div class="vcp__hero-img vcp__hero-img--fallback"></div>
    {% endif %}
    <div class="vcp__hero-overlay" aria-hidden="true"></div>

    <div class="vcp__hero-body">
      <div class="vcp__inner">
        <div class="vcp__hero-text">
        <nav class="vcp__breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          <a href="{{ section.settings.parent_url | default: '/pages/cities' }}">Cities</a>
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          <span aria-current="page">{{ section.settings.city_name }}</span>
        </nav>

        {% if section.settings.hero_label != blank %}
          <div class="vcp__hero-label">
            <svg width="14" height="14" fill="#19aaf8" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
            {{ section.settings.hero_label }}
          </div>
        {% endif %}

        <h1 class="vcp__h1">
          {{ section.settings.heading_before }}
          <span class="vcp__city-accent">{{ section.settings.city_name }}</span>
        </h1>

        {% if section.settings.hero_description != blank %}
          <p class="vcp__hero-desc">{{ section.settings.hero_description }}</p>
        {% endif %}

        <div class="vcp__hero-ctas">
          <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="vcp__btn-primary">
            {{ section.settings.cta_text | default: 'Get a quote' }} in {{ section.settings.city_name }}
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {% if section.settings.phone != blank %}
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="vcp__btn-phone">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
              {{ section.settings.phone }}
            </a>
          {% endif %}
        </div>

        <div class="vcp__trust-row">
          {% if section.settings.trust_1 != blank %}
            <span class="vcp__trust-item">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="transparent"/><polyline points="6,10.5 9,13.5 14,7" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ section.settings.trust_1 }}
            </span>
          {% endif %}
          {% if section.settings.trust_2 != blank %}
            <span class="vcp__trust-item">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="transparent"/><polyline points="6,10.5 9,13.5 14,7" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ section.settings.trust_2 }}
            </span>
          {% endif %}
          {% if section.settings.trust_3 != blank %}
            <span class="vcp__trust-item">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="transparent"/><polyline points="6,10.5 9,13.5 14,7" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ section.settings.trust_3 }}
            </span>
          {% endif %}
          {% if section.settings.trust_4 != blank %}
            <span class="vcp__trust-item">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="transparent"/><polyline points="6,10.5 9,13.5 14,7" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ section.settings.trust_4 }}
            </span>
          {% endif %}
        </div>

        <div class="vcp__hero-sep" aria-hidden="true"></div>

        <div class="vcp__hero-stats">
          {% if section.settings.hstat_1_value != blank %}
            <div class="vcp__hero-stat">
              <div class="vcp__hero-stat-val">{{ section.settings.hstat_1_value }}</div>
              <div class="vcp__hero-stat-lbl">{{ section.settings.hstat_1_label }}</div>
            </div>
          {% endif %}
          {% if section.settings.hstat_2_value != blank %}
            <div class="vcp__hero-stat">
              <div class="vcp__hero-stat-val">{{ section.settings.hstat_2_value }}</div>
              <div class="vcp__hero-stat-lbl">{{ section.settings.hstat_2_label }}</div>
            </div>
          {% endif %}
          {% if section.settings.hstat_3_value != blank %}
            <div class="vcp__hero-stat">
              <div class="vcp__hero-stat-val">{{ section.settings.hstat_3_value }}</div>
              <div class="vcp__hero-stat-lbl">{{ section.settings.hstat_3_label }}</div>
            </div>
          {% endif %}
          {% if section.settings.hstat_4_value != blank %}
            <div class="vcp__hero-stat">
              <div class="vcp__hero-stat-val">{{ section.settings.hstat_4_value }}</div>
              <div class="vcp__hero-stat-lbl">{{ section.settings.hstat_4_label }}</div>
            </div>
          {% endif %}
        </div>
        </div><!-- /vcp__hero-text -->
      </div>
    </div>
  </div>

  <!-- STATS BAR -->
  <div class="vcp__stats-bar">
    <div class="vcp__inner">
      <div class="vcp__stats-card">
      {% if section.settings.stat_1_value != blank %}
        <div class="vcp__stat">
          <span class="vcp__stat-icon" aria-hidden="true"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
          <div><div class="vcp__stat-val">{{ section.settings.stat_1_value }}</div><div class="vcp__stat-lbl">{{ section.settings.stat_1_label }}</div></div>
        </div>
      {% endif %}
      {% if section.settings.stat_2_value != blank %}
        <div class="vcp__stat">
          <span class="vcp__stat-icon" aria-hidden="true"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          <div><div class="vcp__stat-val">{{ section.settings.stat_2_value }}</div><div class="vcp__stat-lbl">{{ section.settings.stat_2_label }}</div></div>
        </div>
      {% endif %}
      {% if section.settings.stat_3_value != blank %}
        <div class="vcp__stat">
          <span class="vcp__stat-icon" aria-hidden="true"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
          <div><div class="vcp__stat-val">{{ section.settings.stat_3_value }}</div><div class="vcp__stat-lbl">{{ section.settings.stat_3_label }}</div></div>
        </div>
      {% endif %}
      {% if section.settings.stat_4_value != blank %}
        <div class="vcp__stat">
          <span class="vcp__stat-icon" aria-hidden="true"><svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>
          <div><div class="vcp__stat-val">{{ section.settings.stat_4_value }}</div><div class="vcp__stat-lbl">{{ section.settings.stat_4_label }}</div></div>
        </div>
      {% endif %}
      </div><!-- /vcp__stats-card -->
    </div>
  </div>

  <!-- SERVICE AREAS DARK CARD -->
  {% if section.settings.areas_heading != blank %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <div class="vcp__areas-card">
          <div class="vcp__areas-left">
            {% if section.settings.areas_label != blank %}
              <span class="vcp__areas-label">{{ section.settings.areas_label }}</span>
            {% endif %}
            <h2 class="vcp__areas-h">{{ section.settings.areas_heading }}</h2>
            {% if section.settings.areas_description != blank %}
              <p class="vcp__areas-desc">{{ section.settings.areas_description }}</p>
            {% endif %}
            {% if section.settings.districts != blank %}
              <div class="vcp__districts">
                {% assign districts = section.settings.districts | split: ',' %}
                {% for d in districts %}
                  <span class="vcp__district">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {{ d | strip }}
                  </span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          <div class="vcp__areas-right">
            <span class="vcp__available">
              <span class="vcp__available-dot" aria-hidden="true"></span>
              {{ section.settings.available_text | default: 'Available today' }}
            </span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- SERVICES GRID -->
  {%- assign service_cards = section.blocks | where: 'type', 'service_card' -%}
  {% if service_cards.size > 0 %}
    <div class="vcp__section">
      <div class="vcp__inner">
        {% if section.settings.services_label != blank %}
          <span class="vcp__label">{{ section.settings.services_label }}</span>
        {% endif %}
        <h2 class="vcp__section-h">{% if section.settings.services_heading != blank %}{{ section.settings.services_heading }}{% else %}We install in {{ section.settings.city_name }}{% endif %}</h2>
        {% if section.settings.services_sub != blank %}
          <p class="vcp__section-sub">{{ section.settings.services_sub }}</p>
        {% endif %}
        <div class="vcp__services-grid">
          {% for b in service_cards %}
            <div class="vcp__service-card" {{ b.shopify_attributes }}>
              <div class="vcp__service-top">
                <div class="vcp__service-icon">
                  {% case b.settings.icon %}
                    {% when 'air-water' %}
                      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10"/><path d="M12 6v6l4 2"/></svg>
                    {% when 'ground' %}
                      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M8 3l4 8 5-5 1 8H6l1-8 5 5z"/><line x1="3" y1="21" x2="21" y2="21"/></svg>
                    {% when 'exhaust' %}
                      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 9c0-3.5-2.5-5.5-5-4.5s-2.5 4 .5 5"/><path d="M15 12c3.5 0 5.5-2.5 4.5-5s-4-2.5-5 .5"/><path d="M12 15c0 3.5 2.5 5.5 5 4.5s2.5-4-.5-5"/><path d="M9 12c-3.5 0-5.5 2.5-4.5 5s4 2.5 5-.5"/></svg>
                    {% else %}
                      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
                  {% endcase %}
                </div>
                {% if b.settings.badge != blank %}
                  <span class="vcp__service-badge">{{ b.settings.badge }}</span>
                {% endif %}
              </div>
              <h3 class="vcp__service-title">{{ b.settings.title }}</h3>
              <p class="vcp__service-desc">{{ b.settings.description }}</p>
              {% if b.settings.price != blank %}
                <p class="vcp__service-price">{{ b.settings.price }}</p>
              {% endif %}
              {% if b.settings.link_url != blank %}
                <a href="{{ b.settings.link_url }}" class="vcp__service-link">
                  Read more
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              {% endif %}
              <a href="{{ b.settings.btn_url | default: section.settings.cta_url | default: '/pages/contact' }}" class="vcp__service-btn{% if b.settings.badge != blank %} vcp__service-btn--primary{% endif %}">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                {{ b.settings.btn_text | default: 'Request a quote' }}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- LOCAL KNOWLEDGE -->
  {% if section.settings.local_heading != blank %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <div class="vcp__local-card">
          <div class="vcp__local-left">
            {% if section.settings.local_label != blank %}
              <span class="vcp__label">{{ section.settings.local_label }}</span>
            {% endif %}
            <h2 class="vcp__section-h" style="font-size:22px;">{{ section.settings.local_heading }}</h2>
            {% if section.settings.local_description != blank %}
              <p class="vcp__local-desc">{{ section.settings.local_description }}</p>
            {% endif %}
          </div>
          <div class="vcp__local-right">
            <div class="vcp__local-rows">
              {% if section.settings.local_house_type != blank %}
                <div class="vcp__local-row">
                  <span class="vcp__local-key">Most common house type</span>
                  <span class="vcp__local-val">{{ section.settings.local_house_type }}</span>
                </div>
              {% endif %}
              {% if section.settings.local_pump_type != blank %}
                <div class="vcp__local-row">
                  <span class="vcp__local-key">Best pump type</span>
                  <span class="vcp__local-val">{{ section.settings.local_pump_type }}</span>
                </div>
              {% endif %}
              {% if section.settings.local_savings != blank %}
                <div class="vcp__local-row">
                  <span class="vcp__local-key">Average savings</span>
                  <span class="vcp__local-val">{{ section.settings.local_savings }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- CUSTOMER CASE -->
  {% if section.settings.case_project != blank %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <div class="vcp__case-card">
          <div class="vcp__case-left">
            {% if section.settings.case_label != blank %}
              <span class="vcp__label">{{ section.settings.case_label }}</span>
            {% endif %}
            {% if section.settings.case_location != blank %}
              <p class="vcp__case-location">{{ section.settings.case_location }}</p>
            {% endif %}
            <h3 class="vcp__case-title">{{ section.settings.case_project }}</h3>
            {% if section.settings.case_result != blank %}
              <span class="vcp__case-result-label">Result</span>
              <p class="vcp__case-result">{{ section.settings.case_result }}</p>
            {% endif %}
          </div>
          <div class="vcp__case-right">
            {% if section.settings.case_quote != blank %}
              <p class="vcp__case-quote"><span class="vcp__case-quotemark" aria-hidden="true">"</span>{{ section.settings.case_quote }}"</p>
            {% endif %}
            {% if section.settings.case_attribution != blank %}
              <p class="vcp__case-attr">— {{ section.settings.case_attribution }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- WHY US -->
  {%- assign why_items = section.blocks | where: 'type', 'why_item' -%}
  {% if why_items.size > 0 %}
    <div class="vcp__section vcp__section--tinted">
      <div class="vcp__inner">
        {% if section.settings.why_label != blank %}
          <span class="vcp__label">{{ section.settings.why_label }}</span>
        {% endif %}
        {% if section.settings.why_heading != blank %}
          <h2 class="vcp__section-h">{{ section.settings.why_heading }}</h2>
        {% else %}
          <h2 class="vcp__section-h">Why choose Varma in {{ section.settings.city_name }}</h2>
        {% endif %}
        <div class="vcp__why-grid">
          {% for b in why_items %}
            <div class="vcp__why-card" {{ b.shopify_attributes }}>
              <div class="vcp__why-icon">
                {% case b.settings.icon %}
                  {% when 'quality' %}
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {% when 'safety' %}
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {% else %}
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  {% endcase %}
              </div>
              <h3 class="vcp__why-title">{{ b.settings.title }}</h3>
              <p class="vcp__why-desc">{{ b.settings.description }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- PROCESS STEPS -->
  {%- assign process_steps = section.blocks | where: 'type', 'process_step' -%}
  {% if process_steps.size > 0 %}
    <div class="vcp__section">
      <div class="vcp__inner">
        {% if section.settings.process_label != blank %}
          <span class="vcp__label">{{ section.settings.process_label }}</span>
        {% endif %}
        <h2 class="vcp__section-h">{{ section.settings.process_heading | default: 'How installation works' }}</h2>
        {% if section.settings.process_sub != blank %}
          <p class="vcp__section-sub">{{ section.settings.process_sub }}</p>
        {% endif %}
        <div class="vcp__process-grid">
          {% for b in process_steps %}
            <div class="vcp__process-card" {{ b.shopify_attributes }}>
              <div class="vcp__process-img-wrap">
                {% if b.settings.image %}
                  {{ b.settings.image | image_url: width: 600 | image_tag: class: 'vcp__process-img', alt: b.settings.title }}
                {% else %}
                  <div class="vcp__process-img vcp__process-img--empty"></div>
                {% endif %}
                <div class="vcp__process-num" aria-hidden="true">{{ forloop.index }}</div>
                <div class="vcp__process-icon-badge">
                  {% case b.settings.icon %}
                    {% when 'home' %}
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    {% when 'document' %}
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    {% when 'tool' %}
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                    {% else %}
                      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72"/></svg>
                  {% endcase %}
                </div>
              </div>
              <h3 class="vcp__process-title">{{ b.settings.title }}</h3>
              <p class="vcp__process-desc">{{ b.settings.description }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- LOCAL EXPERTISE + CONTACT (calc slot left) -->
  {%- assign expertise_items = section.blocks | where: 'type', 'expertise_item' -%}
  {% if expertise_items.size > 0 or section.settings.expertise_heading != blank %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <div class="vcp__expertise-row">
          <div class="vcp__calc-slot"><!-- calculator placeholder --></div>
          <div class="vcp__expertise-right">
            {% if section.settings.expertise_heading != blank %}
              <h2 class="vcp__expertise-h">{{ section.settings.expertise_heading }}</h2>
            {% endif %}
            {% if expertise_items.size > 0 %}
              <ul class="vcp__expertise-list">
                {% for b in expertise_items %}
                  <li {{ b.shopify_attributes }}>
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="#19aaf8" stroke-width="1.5" fill="#e8f6fe"/><polyline points="6,10.5 9,13.5 14,7" stroke="#19aaf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ b.settings.text }}
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
            {% if section.settings.contact_name != blank %}
              <div class="vcp__contact-card">
                <strong>{{ section.settings.contact_name }}</strong>
                {% if section.settings.contact_address != blank %}<span>{{ section.settings.contact_address }}</span>{% endif %}
                {% if section.settings.contact_phone != blank %}<span>Phone: {{ section.settings.contact_phone }}</span>{% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- MAINTENANCE -->
  {%- assign maint_items = section.blocks | where: 'type', 'maintenance_item' -%}
  {% if maint_items.size > 0 %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <div class="vcp__maint-card">
          {% if section.settings.maint_label != blank %}
            <span class="vcp__label">{{ section.settings.maint_label }}</span>
          {% endif %}
          {% if section.settings.maint_heading != blank %}
            <h2 class="vcp__section-h" style="font-size:22px;">{{ section.settings.maint_heading }}</h2>
          {% else %}
            <h2 class="vcp__section-h" style="font-size:22px;">Service & maintenance in {{ section.settings.city_name }}</h2>
          {% endif %}
          {% if section.settings.maint_description != blank %}
            <p class="vcp__maint-desc">{{ section.settings.maint_description }}</p>
          {% endif %}
          <div class="vcp__maint-grid">
            {% for b in maint_items %}
              <div class="vcp__maint-item" {{ b.shopify_attributes }}>
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                {{ b.settings.text }}
              </div>
            {% endfor %}
          </div>
          {% if section.settings.maint_btn_text != blank %}
            <a href="{{ section.settings.maint_btn_url | default: section.settings.cta_url }}" class="vcp__maint-btn">
              {{ section.settings.maint_btn_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- FAQ -->
  {%- assign faqs = section.blocks | where: 'type', 'faq_item' -%}
  {% if faqs.size > 0 %}
    <div class="vcp__section">
      <div class="vcp__inner">
        <h2 class="vcp__section-h">{{ section.settings.faq_title | default: 'Frequently asked questions – heat pump in ' | append: section.settings.city_name }}</h2>
        <div class="vcp__faq">
          {% for b in faqs %}
            <details class="vcp__faq-item" {{ b.shopify_attributes }}>
              <summary class="vcp__faq-q">
                {{ b.settings.question }}
                <svg class="vcp__faq-chev" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="vcp__faq-a">{{ b.settings.answer }}</div>
            </details>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

</div>

{% stylesheet %}
  .vcp { background: #fff; }
  .vcp__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    box-sizing: border-box;
  }
  .vcp__hero-text { max-width: 100%; }
  .vcp__section { padding: 56px 0; }
  .vcp__section--tinted { background: #f5f9fc; }
  .vcp__label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #19aaf8;
    display: block;
    margin-bottom: 10px;
  }
  .vcp__section-h {
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 800;
    color: #224466;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .vcp__section-sub { font-size: 15px; color: #5b6474; margin-bottom: 32px; }

  /* --- HERO --- */
  .vcp__hero {
    position: relative;
    min-height: 640px;
    display: flex;
    flex-direction: column;
  }
  .vcp__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .vcp__hero-img--fallback { background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%); }
  .vcp__hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.20) 55%, transparent 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.45) 60%, rgba(0,0,0,0.60) 100%);
  }
  .vcp__hero-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 72px 0 52px;
    flex: 1;
  }
  .vcp__breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .vcp__breadcrumb a { color: rgba(255,255,255,0.65); text-decoration: none; }
  .vcp__breadcrumb a:hover { color: #fff; }
  .vcp__breadcrumb span { color: rgba(255,255,255,0.9); }
  .vcp__hero-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #19aaf8;
    margin-bottom: 14px;
  }
  .vcp__h1 {
    font-size: clamp(36px, 5vw, 62px);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 18px;
  }
  .vcp__city-accent { color: #222299; }
  .vcp__hero-desc {
    font-size: 17px;
    color: rgba(255,255,255,0.80);
    line-height: 1.65;
    max-width: 560px;
    margin-bottom: 28px;
  }
  .vcp__hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .vcp__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #222299;
    color: #fff;
    padding: 13px 24px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .vcp__btn-primary:hover { background: rgba(34,34,153,0.9); }
  .vcp__btn-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.35);
    padding: 13px 24px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .vcp__btn-phone:hover { background: rgba(255,255,255,0.20); }
  .vcp__trust-row { display: flex; flex-wrap: wrap; gap: 12px 20px; margin-bottom: 24px; }
  .vcp__trust-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: rgba(255,255,255,0.80);
    font-weight: 500;
  }
  .vcp__hero-sep {
    height: 1px;
    background: rgba(255,255,255,0.18);
    margin-bottom: 24px;
  }
  .vcp__hero-stats { display: flex; gap: 40px; flex-wrap: wrap; }
  .vcp__hero-stat-val {
    font-size: 28px;
    font-weight: 800;
    color: #222299;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .vcp__hero-stat-lbl { font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 4px; }

  /* --- STATS BAR --- */
  .vcp__stats-bar {
    padding: 40px 0 0;
    background: #fff;
  }
  .vcp__stats-bar .vcp__inner { padding: 0 32px; }
  .vcp__stats-card {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    border: 1.5px solid #e6e8ef;
    border-radius: 14px;
    padding: 20px 24px;
  }
  .vcp__stat { display: flex; align-items: center; gap: 12px; }
  .vcp__stat-icon {
    width: 40px;
    height: 40px;
    background: #e8f6fe;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .vcp__stat-val { font-size: 15px; font-weight: 700; color: #224466; }
  .vcp__stat-lbl { font-size: 13px; color: #5b6474; }

  /* --- SERVICE AREAS CARD --- */
  .vcp__areas-card {
    background: linear-gradient(135deg, #0b1220 0%, #1e47b8 100%);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    padding: 56px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 32px;
  }
  .vcp__areas-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgb(255,255,255) 1px, transparent 0px);
    background-size: 22px 22px;
    opacity: 0.06;
    pointer-events: none;
  }
  .vcp__areas-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    display: block;
    margin-bottom: 10px;
  }
  .vcp__areas-h {
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .vcp__areas-desc { font-size: 14px; color: rgba(255,255,255,0.65); margin-bottom: 20px; line-height: 1.6; }
  .vcp__districts { display: flex; flex-wrap: wrap; gap: 8px; }
  .vcp__district {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }
  .vcp__available {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .vcp__available-dot {
    width: 8px;
    height: 8px;
    background: #4ade80;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* --- SERVICES GRID --- */
  .vcp__services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 28px;
  }
  .vcp__service-card {
    border: 1.5px solid #e6e8ef;
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .vcp__service-card:hover { box-shadow: 0 8px 24px rgba(34,68,102,0.10); transform: translateY(-4px); }
  .vcp__service-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 4px; }
  .vcp__service-icon {
    width: 44px;
    height: 44px;
    background: #e8f6fe;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vcp__service-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: #224466;
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
  }
  .vcp__service-title { font-size: 15px; font-weight: 700; color: #224466; }
  .vcp__service-desc { font-size: 13px; color: #5b6474; line-height: 1.5; flex: 1; }
  .vcp__service-price { font-size: 13px; color: #5b6474; }
  .vcp__service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #19aaf8;
    text-decoration: none;
    transition: gap 0.15s;
  }
  .vcp__service-link:hover { gap: 10px; }
  .vcp__service-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(34,34,153,0.06);
    color: #19aaf8;
    border: 1.5px solid #19aaf8;
    border-radius: 8px;
    padding: 10px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    margin-top: 4px;
  }
  .vcp__service-btn:hover { background: #e8f6fe; color: #0d1b2e; }
  .vcp__service-btn--primary { background: #19aaf8; color: #fff; border-color: #19aaf8; }
  .vcp__service-btn--primary:hover { background: #0e99e0; color: #fff; }

  /* --- LOCAL KNOWLEDGE --- */
  .vcp__local-card {
    border: 1.5px solid #e6e8ef;
    border-radius: 14px;
    padding: 32px 36px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .vcp__local-desc { font-size: 14px; color: #5b6474; line-height: 1.7; margin-top: 12px; }
  .vcp__local-rows { display: flex; flex-direction: column; gap: 10px; }
  .vcp__local-row {
    border: 1.5px solid #e6e8ef;
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .vcp__local-key { font-size: 14px; color: #5b6474; }
  .vcp__local-val { font-size: 14px; font-weight: 700; color: #19aaf8; text-align: right; }

  /* --- CUSTOMER CASE --- */
  .vcp__case-card {
    border: 1.5px solid #e6e8ef;
    border-radius: 16px;
    padding: 40px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .vcp__case-location { font-size: 13px; color: #5b6474; margin: 6px 0 4px; }
  .vcp__case-title { font-size: 22px; font-weight: 800; color: #0d1b2e; margin-bottom: 20px; line-height: 1.2; }
  .vcp__case-result-label { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #5b6474; display: block; margin-bottom: 6px; }
  .vcp__case-result { font-size: 16px; font-weight: 700; color: #19aaf8; line-height: 1.4; }
  .vcp__case-quotemark { font-size: 80px; font-family: Georgia, serif; color: #19aaf8; line-height: 0.6; display: inline; vertical-align: top; margin-right: 6px; }
  .vcp__case-quote { font-size: 18px; font-style: italic; color: #0d1b2e; line-height: 1.6; }
  .vcp__case-attr { font-size: 14px; color: #5b6474; margin-top: 16px; }

  /* --- WHY US --- */
  .vcp__why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 28px;
  }
  .vcp__why-card {
    background: #fff;
    border: 1.5px solid #e6e8ef;
    border-radius: 14px;
    padding: 24px;
  }
  .vcp__why-icon {
    width: 48px;
    height: 48px;
    background: #e8f6fe;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .vcp__why-title { font-size: 16px; font-weight: 700; color: #224466; margin-bottom: 8px; }
  .vcp__why-desc { font-size: 14px; color: #5b6474; line-height: 1.6; }

  /* --- PROCESS --- */
  .vcp__process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 28px;
  }
  .vcp__process-card { border-radius: 14px; overflow: hidden; border: 1.5px solid #e6e8ef; }
  .vcp__process-img-wrap { position: relative; aspect-ratio: 4/3; background: #e8f6fe; }
  .vcp__process-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vcp__process-img--empty { width: 100%; height: 100%; background: linear-gradient(135deg, #e8f6fe, #c7e8fc); }
  .vcp__process-num {
    position: absolute;
    top: 12px;
    left: 12px;
    width: 28px;
    height: 28px;
    background: #fff;
    color: #224466;
    font-size: 13px;
    font-weight: 800;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vcp__process-icon-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    width: 36px;
    height: 36px;
    background: #fff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #19aaf8;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }
  .vcp__process-title { font-size: 15px; font-weight: 700; color: #224466; padding: 14px 16px 4px; }
  .vcp__process-desc { font-size: 13px; color: #5b6474; padding: 0 16px 16px; line-height: 1.5; }

  /* --- EXPERTISE + CONTACT --- */
  .vcp__expertise-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .vcp__calc-slot { min-height: 200px; }
  .vcp__expertise-h { font-size: 20px; font-weight: 700; color: #224466; margin-bottom: 20px; }
  .vcp__expertise-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .vcp__expertise-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: #2a2f3d;
    line-height: 1.5;
  }
  .vcp__expertise-list li svg { flex-shrink: 0; margin-top: 1px; }
  .vcp__contact-card {
    border: 1.5px solid #e6e8ef;
    border-radius: 10px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 14px;
    color: #5b6474;
  }
  .vcp__contact-card strong { color: #224466; font-size: 15px; margin-bottom: 4px; }

  /* --- MAINTENANCE --- */
  .vcp__maint-card {
    border: 1.5px solid #e6e8ef;
    border-radius: 14px;
    padding: 32px 36px;
  }
  .vcp__maint-desc { font-size: 14px; color: #5b6474; line-height: 1.65; margin-bottom: 24px; }
  .vcp__maint-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px 24px;
    margin-bottom: 24px;
  }
  .vcp__maint-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: #2a2f3d;
  }
  .vcp__maint-btn {
    display: inline-flex;
    align-items: center;
    background: #222299;
    color: #fff;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .vcp__maint-btn:hover { background: rgba(34,34,153,0.9); }

  /* --- FAQ --- */
  .vcp__faq { display: flex; flex-direction: column; gap: 2px; margin-top: 20px; }
  .vcp__faq-item { border: 1.5px solid #e6e8ef; border-radius: 10px; overflow: hidden; }
  .vcp__faq-item[open] { border-color: #19aaf8; }
  .vcp__faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    font-size: 15px;
    font-weight: 600;
    color: #224466;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .vcp__faq-q::-webkit-details-marker { display: none; }
  .vcp__faq-q:hover { background: #f5f9fc; }
  .vcp__faq-chev { flex-shrink: 0; transition: transform 0.2s; color: #5b6474; }
  .vcp__faq-item[open] .vcp__faq-chev { transform: rotate(180deg); }
  .vcp__faq-a { padding: 0 20px 16px; font-size: 14px; color: #5b6474; line-height: 1.7; }

  /* --- RESPONSIVE --- */
  @media (max-width: 960px) {
    .vcp__stats-card { grid-template-columns: repeat(2, 1fr); }
    .vcp__services-grid { grid-template-columns: repeat(2, 1fr); }
    .vcp__why-grid { grid-template-columns: 1fr 1fr; }
    .vcp__process-grid { grid-template-columns: repeat(2, 1fr); }
    .vcp__local-card { grid-template-columns: 1fr; }
    .vcp__expertise-row { grid-template-columns: 1fr; }
    .vcp__calc-slot { display: none; }
    .vcp__maint-grid { grid-template-columns: 1fr 1fr; }
    .vcp__areas-card { flex-direction: column; }
  }
  @media (max-width: 600px) {
    .vcp__inner { padding: 0 20px; }
    .vcp__hero-body { padding: 48px 0 36px; }
    .vcp__services-grid { grid-template-columns: 1fr; }
    .vcp__why-grid { grid-template-columns: 1fr; }
    .vcp__process-grid { grid-template-columns: 1fr 1fr; }
    .vcp__maint-grid { grid-template-columns: 1fr; }
    .vcp__hero-stats { gap: 20px; }
    .vcp__areas-card { padding: 24px; }
  }
{% endstylesheet %}

