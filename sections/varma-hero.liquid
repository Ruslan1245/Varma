<section class="v-hero full-width">
  <div class="v-hero__bg" aria-hidden="true">
    {% if section.settings.bg_image %}
      {{ section.settings.bg_image | image_url: width: 2560 | image_tag: class: 'v-hero__bg-img', loading: 'eager', fetchpriority: 'high', alt: '' }}
    {% else %}
      <div class="v-hero__bg-placeholder"></div>
    {% endif %}
    <div class="v-hero__bg-overlay"></div>
  </div>

  <div class="v-hero__overlay-content">
    <div class="v-hero__container">
      <div class="v-hero__content">
        {% if section.settings.badge_text != blank %}
          <div class="v-hero__badge">
            <span class="v-hero__badge-dot" aria-hidden="true"></span>
            {{ section.settings.badge_text }}
          </div>
        {% endif %}

        <h1 class="v-hero__heading">
          {{ section.settings.heading_before }}
          <span class="v-hero__heading-accent">{{ section.settings.heading_accent }}</span>
          {{ section.settings.heading_after }}
        </h1>

        {% if section.settings.description != blank %}
          <p class="v-hero__desc">{{ section.settings.description }}</p>
        {% endif %}

        <div class="v-hero__ctas">
          {% if section.settings.cta_primary_text != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="v-hero__btn v-hero__btn--primary">
              {{ section.settings.cta_primary_text }}
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {% endif %}
          {% if section.settings.cta_secondary_text != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="v-hero__btn v-hero__btn--secondary">
              {{ section.settings.cta_secondary_text }}
            </a>
          {% endif %}
        </div>

        <div class="v-hero__trust">
          {% if section.settings.trust_1 != blank %}
            <span class="v-hero__trust-item">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {{ section.settings.trust_1 }}
            </span>
          {% endif %}
          {% if section.settings.trust_2 != blank %}
            <span class="v-hero__trust-item">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {{ section.settings.trust_2 }}
            </span>
          {% endif %}
          {% if section.settings.trust_3 != blank %}
            <span class="v-hero__trust-item">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {{ section.settings.trust_3 }}
            </span>
          {% endif %}
        </div>
      </div>

      <div class="v-hero__widgets">
        <div class="v-hero__widget">
          <div class="v-hero__widget-icon" aria-hidden="true">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
          </div>
          <div>
            <div class="v-hero__widget-value">{{ section.settings.widget1_value }}</div>
            <div class="v-hero__widget-label">{{ section.settings.widget1_label }}</div>
          </div>
        </div>
        <div class="v-hero__widget">
          <div class="v-hero__widget-icon v-hero__widget-icon--green" aria-hidden="true">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#16A34A" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <div>
            <div class="v-hero__widget-value">{{ section.settings.widget2_value }}</div>
            <div class="v-hero__widget-label">{{ section.settings.widget2_label }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* Section: image sets the height naturally — no cropping */
  .v-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  /* BG layer: fills the section, height = image height */
  .v-hero__bg {
    position: relative;
    width: 100%;
  }
  .v-hero__bg-img {
    width: 100%;
    height: auto !important;
    display: block;
    max-width: none;
  }
  .v-hero__bg-placeholder {
    width: 100%;
    aspect-ratio: 2560 / 1756;
    background: linear-gradient(135deg, #0f1e35 0%, #224466 100%);
  }
  .v-hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(8, 16, 30, 0.72) 0%,
      rgba(8, 16, 30, 0.42) 42%,
      rgba(8, 16, 30, 0.08) 68%,
      rgba(8, 16, 30, 0.00) 100%
    );
  }

  /* Content layer: sits on top of image */
  .v-hero__overlay-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    z-index: 2;
    line-height: 1.55;
  }
  .v-hero__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }
  .v-hero__content {
    max-width: 540px;
    flex-shrink: 0;
  }
  .v-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.22);
    color: rgba(255,255,255,0.92);
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 22px;
    backdrop-filter: blur(6px);
  }
  .v-hero__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #19aaf8;
    flex-shrink: 0;
  }
  .v-hero__heading {
    font-size: clamp(36px, 4vw, 54px);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .v-hero__heading-accent { color: #19aaf8; }
  .v-hero__desc {
    font-size: 17px;
    color: rgba(255,255,255,0.78);
    line-height: 1.65;
    margin-bottom: 32px;
    max-width: 460px;
  }
  .v-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }
  .v-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
  }
  .v-hero__btn--primary { background: #222299; color: #fff; }
  .v-hero__btn--primary:hover { background: rgba(34,34,153,0.9); }
  .v-hero__btn--secondary {
    background: rgba(255,255,255,0.10);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.32);
    backdrop-filter: blur(6px);
  }
  .v-hero__btn--secondary:hover { background: rgba(255,255,255,0.18); }
  .v-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 22px;
  }
  .v-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    color: rgba(255,255,255,0.72);
    font-weight: 500;
  }
  .v-hero__widgets {
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex-shrink: 0;
  }
  .v-hero__widget {
    background: rgba(255,255,255,0.94);
    border-radius: 14px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.22);
    backdrop-filter: blur(8px);
    min-width: 185px;
  }
  .v-hero__widget-icon {
    width: 40px;
    height: 40px;
    background: #e8f6fe;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-hero__widget-icon--green { background: #F0FDF4; }
  .v-hero__widget-value {
    font-size: 18px;
    font-weight: 700;
    color: #224466;
    line-height: 1.2;
  }
  .v-hero__widget-label {
    font-size: 12px;
    color: #5b6474;
    margin-top: 2px;
  }
  @media (max-width: 768px) {
    .v-hero__container { flex-direction: column; align-items: flex-start; padding: 0 24px; }
    .v-hero__widgets { flex-direction: row; }
    .v-hero__widget { min-width: 0; }
    .v-hero__bg-img { min-height: 480px; object-fit: cover; object-position: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Authorized · Certified · Swedish-owned"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before accent)",
      "default": "Stockholm's"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent word (blue)",
      "default": "smartest"
    },
    {
      "type": "textarea",
      "id": "heading_after",
      "label": "Heading (after accent)",
      "default": "experts in heating and cooling."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Fast emergency response throughout Greater Stockholm with energy-efficient heat pumps and geothermal heating that reduce electricity bills by up to 70%."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA text",
      "default": "Book a free consultation"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Calculate my savings"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust badge 1",
      "default": "500+ homes served in Stockholm"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust badge 2",
      "default": "Booking synced with Outlook"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust badge 3",
      "default": "AI chat around the clock"
    },
    {
      "type": "text",
      "id": "widget1_value",
      "label": "Widget 1 value",
      "default": "21.5°C"
    },
    {
      "type": "text",
      "id": "widget1_label",
      "label": "Widget 1 label",
      "default": "Indoors · optimal"
    },
    {
      "type": "text",
      "id": "widget2_value",
      "label": "Widget 2 value",
      "default": "-68%"
    },
    {
      "type": "text",
      "id": "widget2_label",
      "label": "Widget 2 label",
      "default": "Avg. heating cost"
    }
  ],
  "presets": [{ "name": "Varma Hero" }]
}
{% endschema %}
