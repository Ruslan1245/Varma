<section class="v-hero full-width">
  <div class="v-hero__container">
    <div class="v-hero__content">
      {% if section.settings.badge_text != blank %}
        <div class="v-hero__badge">
          <span class="v-hero__badge-dot" aria-hidden="true"></span>
          {{ section.settings.badge_text }}
        </div>
      {% endif %}

      <h1 class="v-hero__heading">
        {{ section.settings.heading_before }}
        <span class="v-hero__heading-accent">{{ section.settings.heading_accent }}</span>
        {{ section.settings.heading_after }}
      </h1>

      {% if section.settings.description != blank %}
        <p class="v-hero__desc">{{ section.settings.description }}</p>
      {% endif %}

      <div class="v-hero__ctas">
        {% if section.settings.cta_primary_text != blank %}
          <a href="{{ section.settings.cta_primary_url }}" class="v-hero__btn v-hero__btn--primary">
            {{ section.settings.cta_primary_text }}
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
        {% if section.settings.cta_secondary_text != blank %}
          <a href="{{ section.settings.cta_secondary_url }}" class="v-hero__btn v-hero__btn--secondary">
            {{ section.settings.cta_secondary_text }}
          </a>
        {% endif %}
      </div>

      <div class="v-hero__trust">
        {% if section.settings.trust_1 != blank %}
          <span class="v-hero__trust-item">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {{ section.settings.trust_1 }}
          </span>
        {% endif %}
        {% if section.settings.trust_2 != blank %}
          <span class="v-hero__trust-item">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {{ section.settings.trust_2 }}
          </span>
        {% endif %}
        {% if section.settings.trust_3 != blank %}
          <span class="v-hero__trust-item">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {{ section.settings.trust_3 }}
          </span>
        {% endif %}
      </div>
    </div>

    <div class="v-hero__image-wrap">
      {% if section.settings.hero_image %}
        {{ section.settings.hero_image | image_url: width: 700 | image_tag: class: 'v-hero__image', loading: 'eager', alt: section.settings.hero_image.alt }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'v-hero__image v-hero__image--placeholder' }}
      {% endif %}

      <div class="v-hero__widget v-hero__widget--top">
        <div class="v-hero__widget-icon" aria-hidden="true">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
        </div>
        <div>
          <div class="v-hero__widget-value">{{ section.settings.widget1_value | default: '21.5В°C' }}</div>
          <div class="v-hero__widget-label">{{ section.settings.widget1_label | default: 'Inomhus В· optimal' }}</div>
        </div>
      </div>

      <div class="v-hero__widget v-hero__widget--bottom">
        <div class="v-hero__widget-icon v-hero__widget-icon--green" aria-hidden="true">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#16A34A" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        </div>
        <div>
          <div class="v-hero__widget-value">{{ section.settings.widget2_value | default: '-68%' }}</div>
          <div class="v-hero__widget-label">{{ section.settings.widget2_label | default: 'Snitt vГ¤rmekostnad' }}</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .v-hero {
    padding: 64px 0 80px;
    background: #fff;
  }
  .v-hero__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .v-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #e8f6fe;
    border: 1px solid #c7e8fc;
    color: #1876b5;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .v-hero__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #19aaf8;
    flex-shrink: 0;
  }
  .v-hero__heading {
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 800;
    color: #224466;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .v-hero__heading-accent {
    color: #19aaf8;
  }
  .v-hero__desc {
    font-size: 17px;
    color: #5b6474;
    line-height: 1.65;
    margin-bottom: 32px;
    max-width: 480px;
  }
  .v-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }
  .v-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
  }
  .v-hero__btn--primary {
    background: #19aaf8;
    color: white;
  }
  .v-hero__btn--primary:hover { background: #0e8fd6; }
  .v-hero__btn--secondary {
    background: white;
    color: #224466;
    border: 1.5px solid #c7e8fc;
  }
  .v-hero__btn--secondary:hover { border-color: #5b6474; }
  .v-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 24px;
  }
  .v-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    color: #2a2f3d;
    font-weight: 500;
  }
  .v-hero__image-wrap {
    position: relative;
  }
  .v-hero__image {
    width: 100%;
    border-radius: 20px;
    object-fit: cover;
    aspect-ratio: 4/3;
  }
  .v-hero__image--placeholder {
    background: #e6e8ef;
    border-radius: 20px;
    width: 100%;
    aspect-ratio: 4/3;
  }
  .v-hero__widget {
    position: absolute;
    background: white;
    border-radius: 14px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    min-width: 160px;
  }
  .v-hero__widget--top {
    top: -16px;
    left: -16px;
  }
  .v-hero__widget--bottom {
    bottom: 24px;
    right: -16px;
  }
  .v-hero__widget-icon {
    width: 38px;
    height: 38px;
    background: #e8f6fe;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-hero__widget-icon--green { background: #F0FDF4; }
  .v-hero__widget-value {
    font-size: 18px;
    font-weight: 700;
    color: #224466;
    line-height: 1.2;
  }
  .v-hero__widget-label {
    font-size: 12px;
    color: #5b6474;
    margin-top: 2px;
  }
  @media (max-width: 900px) {
    .v-hero__container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .v-hero__image-wrap { order: -1; }
    .v-hero__widget--top { left: 8px; }
    .v-hero__widget--bottom { right: 8px; }
  }
{% endstylesheet %}

