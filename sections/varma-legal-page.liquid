<div class="vlp__hero full-width">
  <div class="vlp__hero-inner">
    <nav class="vlp__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>{{ page.title }}</span>
    </nav>
    <h1 class="vlp__heading">{{ page.title }}</h1>
  </div>
</div>

<div class="vlp__body full-width">
  <div class="vlp__body-inner vlp__content">
    {% if section.settings.intro != blank %}
      <p class="vlp__intro">{{ section.settings.intro }}</p>
    {% endif %}
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="vlp__section" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h2 class="vlp__sh">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.body != blank %}
            <p class="vlp__sp">{{ block.settings.body }}</p>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      {{ page.content }}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .vlp__hero {
    background: #e8f6fe;
    padding: 52px 0 44px;
  }
  .vlp__hero-inner,
  .vlp__body-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .vlp__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #5b6474;
    margin-bottom: 16px;
  }
  .vlp__breadcrumb a {
    color: #5b6474;
    text-decoration: none;
  }
  .vlp__breadcrumb a:hover { color: #19aaf8; }
  .vlp__heading {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    color: #224466;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .vlp__body {
    background: white;
    padding: 56px 0 80px;
  }
  .vlp__intro {
    font-size: 15px;
    color: #5b6474;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .vlp__section {
    margin-bottom: 28px;
  }
  .vlp__sh {
    font-size: 18px;
    font-weight: 700;
    color: #19aaf8;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .vlp__sp {
    font-size: 15px;
    color: #5b6474;
    line-height: 1.7;
    margin: 0;
  }
  .vlp__content p {
    font-size: 15px;
    color: #5b6474;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .vlp__content h2 {
    font-size: 20px;
    font-weight: 700;
    color: #19aaf8;
    margin: 32px 0 8px;
    line-height: 1.3;
  }
  .vlp__content h3 {
    font-size: 17px;
    font-weight: 700;
    color: #224466;
    margin: 24px 0 6px;
  }
  .vlp__content a {
    color: #19aaf8;
    text-decoration: underline;
  }
  .vlp__content ul,
  .vlp__content ol {
    padding-left: 20px;
    margin-bottom: 16px;
    color: #5b6474;
    font-size: 15px;
    line-height: 1.7;
  }
  @media (max-width: 600px) {
    .vlp__hero-inner,
    .vlp__body-inner { padding: 0 20px; }
    .vlp__hero { padding: 36px 0 32px; }
    .vlp__body { padding: 40px 0 60px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Legal page",
  "blocks": [
    {
      "type": "legal_section",
      "name": "Section",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro paragraph"
    }
  ],
  "presets": [{ "name": "Legal page" }]
}
{% endschema %}
