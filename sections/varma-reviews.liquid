<section class="v-reviews">
  <div class="v-reviews__container">
    {% if section.settings.label != blank %}
      <p class="v-label v-reviews__label">{{ section.settings.label }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="v-reviews__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="v-reviews__stats">
      {% if section.settings.stat1_value != blank %}
        <div class="v-reviews__stat">
          <div class="v-reviews__stat-value">
            {{ section.settings.stat1_value }}
            {% if section.settings.stat1_show_star %}<span class="v-reviews__star" aria-hidden="true">&#9733;</span>{% endif %}
          </div>
          <div class="v-reviews__stat-label">{{ section.settings.stat1_label }}</div>
        </div>
      {% endif %}
      {% if section.settings.stat2_value != blank %}
        <div class="v-reviews__stat">
          <div class="v-reviews__stat-value">
            {{ section.settings.stat2_value }}
            {% if section.settings.stat2_show_star %}<span class="v-reviews__star" aria-hidden="true">&#9733;</span>{% endif %}
          </div>
          <div class="v-reviews__stat-label">{{ section.settings.stat2_label }}</div>
        </div>
      {% endif %}
      {% if section.settings.stat3_value != blank %}
        <div class="v-reviews__stat">
          <div class="v-reviews__stat-value">{{ section.settings.stat3_value }}</div>
          <div class="v-reviews__stat-label">{{ section.settings.stat3_label }}</div>
        </div>
      {% endif %}
      {% if section.settings.stat4_value != blank %}
        <div class="v-reviews__stat">
          <div class="v-reviews__stat-value">{{ section.settings.stat4_value }}</div>
          <div class="v-reviews__stat-label">{{ section.settings.stat4_label }}</div>
        </div>
      {% endif %}
    </div>

    <div class="v-reviews__grid">
      {% for block in section.blocks %}
        <div class="v-reviews__card" {{ block.shopify_attributes }}>
          <div class="v-reviews__stars" aria-label="5 stars">
            {% for i in (1..5) %}&#9733;{% endfor %}
          </div>
          <p class="v-reviews__quote">{{ block.settings.quote }}</p>
          <div class="v-reviews__author">
            <div class="v-reviews__avatar" aria-hidden="true">
              {{ block.settings.name | slice: 0 | upcase }}{{ block.settings.last_initial | upcase }}
            </div>
            <div>
              <div class="v-reviews__name">{{ block.settings.name }}</div>
              <div class="v-reviews__meta">{{ block.settings.location }} · {{ block.settings.service }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-reviews {
    padding: 80px 0;
    background: #fff;
  }
  .v-reviews__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .v-reviews__label { margin-bottom: 12px; }
  .v-reviews__heading {
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 800;
    color: #0F172A;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 48px;
  }
  .v-reviews__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 56px;
    padding-bottom: 48px;
    border-bottom: 1px solid #E2E8F0;
  }
  .v-reviews__stat { text-align: center; }
  .v-reviews__stat-value {
    font-size: 40px;
    font-weight: 800;
    color: #0F172A;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    line-height: 1;
    margin-bottom: 8px;
  }
  .v-reviews__star { color: #F59E0B; font-size: 32px; }
  .v-reviews__stat-label {
    font-size: 14px;
    color: #64748B;
  }
  .v-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .v-reviews__card {
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 28px;
  }
  .v-reviews__stars {
    color: #F59E0B;
    font-size: 18px;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .v-reviews__quote {
    font-size: 15px;
    color: #1E293B;
    line-height: 1.65;
    margin-bottom: 24px;
    flex: 1;
  }
  .v-reviews__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .v-reviews__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #EFF6FF;
    color: #2563EB;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-reviews__name {
    font-size: 14px;
    font-weight: 700;
    color: #0F172A;
  }
  .v-reviews__meta {
    font-size: 13px;
    color: #64748B;
    margin-top: 2px;
  }
  @media (max-width: 900px) {
    .v-reviews__stats { grid-template-columns: repeat(2, 1fr); }
    .v-reviews__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Customer review goes here."
        },
        {
          "type": "text",
          "id": "name",
          "label": "First name",
          "default": "Anna"
        },
        {
          "type": "text",
          "id": "last_initial",
          "label": "Last name initial",
          "default": "N"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Stockholm"
        },
        {
          "type": "text",
          "id": "service",
