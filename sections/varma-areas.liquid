<section class="v-areas full-width">
  <div class="v-areas__container">
    {% if section.settings.label != blank %}
      <p class="v-label">{{ section.settings.label }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="v-areas__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="v-areas__desc">{{ section.settings.description }}</p>
    {% endif %}
    {% if section.settings.status_text != blank %}
      <div class="v-areas__status">
        <span class="v-areas__status-dot" aria-hidden="true"></span>
        {{ section.settings.status_text }}
      </div>
    {% endif %}

    <div class="v-areas__grid">
      {% for block in section.blocks %}
        <div class="v-areas__card" {{ block.shopify_attributes }}>
          <div class="v-areas__card-header">
            <span class="v-areas__card-name">{{ block.settings.name }}</span>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          {% if block.settings.technicians != blank %}
            <p class="v-areas__card-info">{{ block.settings.technicians }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .v-areas {
    padding: 80px 0;
    background: #fff;
  }
  .v-areas__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .v-areas__heading {
    font-size: clamp(26px, 3vw, 40px);
    font-weight: 800;
    color: #224466;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }
  .v-areas__desc {
    font-size: 16px;
    color: #5b6474;
    margin-bottom: 20px;
  }
  .v-areas__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #2a2f3d;
    margin-bottom: 36px;
  }
  .v-areas__status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #22C55E;
    flex-shrink: 0;
  }
  .v-areas__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .v-areas__card {
    background: white;
    border: 1px solid #e6e8ef;
    border-radius: 12px;
    padding: 18px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .v-areas__card:hover {
    border-color: #c7e8fc;
    box-shadow: 0 2px 12px rgba(37,99,235,0.08);
  }
  .v-areas__card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .v-areas__card-name {
    font-size: 15px;
    font-weight: 700;
    color: #224466;
  }
  .v-areas__card-info {
    font-size: 13px;
    color: #5b6474;
  }
  @media (max-width: 1000px) {
    .v-areas__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .v-areas__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

