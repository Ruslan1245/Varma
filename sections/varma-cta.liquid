<section class="v-cta full-width">
  <div class="v-cta__container">
    <div class="v-cta__inner">
      <div class="v-cta__text">
        {% if section.settings.heading != blank %}
          <h2 class="v-cta__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="v-cta__desc">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      <div class="v-cta__actions">
        {% if section.settings.btn1_text != blank %}
          <a href="{{ section.settings.btn1_url }}" class="v-cta__btn v-cta__btn--white">
            {{ section.settings.btn1_text }}
          </a>
        {% endif %}
        {% if section.settings.btn2_text != blank %}
          <a href="{{ section.settings.btn2_url }}" class="v-cta__btn v-cta__btn--outline">
            {{ section.settings.btn2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .v-cta {
    padding: 40px 0;
    background: #fff;
  }
  .v-cta__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .v-cta__inner {
    background: linear-gradient(135deg, #2A5FE0 0%, #1E47B8 100%);
    border-radius: 20px;
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .v-cta__heading {
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 800;
    color: white;
    line-height: 1.2;
    margin-bottom: 10px;
  }
  .v-cta__desc {
    font-size: 15px;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    max-width: 500px;
  }
  .v-cta__actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .v-cta__btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .v-cta__btn--white {
    background: white;
    color: #19aaf8;
  }
  .v-cta__btn--white:hover { background: #F0F9FF; }
  .v-cta__btn--outline {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .v-cta__btn--outline:hover { border-color: white; }
  @media (max-width: 700px) {
    .v-cta__inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 32px 24px;
    }
  }
{% endstylesheet %}

