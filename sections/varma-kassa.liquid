<div class="vk full-width">
  <div class="vk__container">

    {% if cart.item_count == 0 %}
      <div class="vk__empty">
        <h1>Your cart is empty</h1>
        <a href="/pages/shop" class="vk__empty-btn">Browse products</a>
      </div>
    {% else %}

      <div class="vk__layout">

        {%- comment -%} LEFT COLUMN — form {%- endcomment -%}
        <div class="vk__left">
          <h1 class="vk__heading">Checkout</h1>
          <p class="vk__subheading">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Secure payment – complete installation included
          </p>

          {% form 'cart', cart, id: 'vk-form' %}
            {%- comment -%} Step 1 — Contact details {%- endcomment -%}
            <div class="vk__step">
              <div class="vk__step-header">
                <span class="vk__step-num">1</span>
                <h2 class="vk__step-title">Your details</h2>
              </div>
              <div class="vk__fields">
                <div class="vk__field-row">
                  <label class="vk__label">First name <span class="vk__req">*</span>
                    <input type="text" name="attributes[first_name]" class="vk__input" value="{{ cart.attributes.first_name }}" required placeholder="Anna">
                  </label>
                  <label class="vk__label">Last name <span class="vk__req">*</span>
                    <input type="text" name="attributes[last_name]" class="vk__input" value="{{ cart.attributes.last_name }}" required placeholder="Lindgren">
                  </label>
                </div>
                <label class="vk__label">Email <span class="vk__req">*</span>
                  <input type="email" name="attributes[email]" class="vk__input" value="{{ cart.attributes.email }}" required placeholder="anna@example.se">
                </label>
                <label class="vk__label">Phone <span class="vk__req">*</span>
                  <input type="tel" name="attributes[phone]" class="vk__input" value="{{ cart.attributes.phone }}" required placeholder="070 123 45 67">
                </label>
              </div>
            </div>

            {%- comment -%} Step 2 — ROT details {%- endcomment -%}
            <div class="vk__step">
              <div class="vk__step-header">
                <span class="vk__step-num">2</span>
                <h2 class="vk__step-title">ROT information</h2>
              </div>
              <div class="vk__rot-note">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
                The price at checkout already includes the ROT deduction (15%). We apply for the deduction from Skatteverket on your behalf.
              </div>
              <div class="vk__fields">
                <label class="vk__label">Personal number <span class="vk__req">*</span>
                  <input type="text" name="attributes[personnummer]" class="vk__input" value="{{ cart.attributes.personnummer }}" required placeholder="YYMMDD-XXXX or YYYYMMDD-XXXX">
                  <span class="vk__hint">10 or 12 digits. Required for ROT application with Skatteverket.</span>
                </label>
                <label class="vk__label">Installation address <span class="vk__req">*</span>
                  <input type="text" name="attributes[installation_address]" class="vk__input" value="{{ cart.attributes.installation_address }}" required placeholder="Street address, postcode and city where installation will be carried out">
                </label>
                <div class="vk__label">Property type <span class="vk__req">*</span>
                  <div class="vk__radio-row">
                    <label class="vk__radio {% if cart.attributes.property_type == 'villa' or cart.attributes.property_type == blank %}vk__radio--selected{% endif %}">
                      <input type="radio" name="attributes[property_type]" value="villa" {% if cart.attributes.property_type == 'villa' or cart.attributes.property_type == blank %}checked{% endif %}> Villa / detached house (property designation)
                    </label>
                    <label class="vk__radio {% if cart.attributes.property_type == 'brf' %}vk__radio--selected{% endif %}">
                      <input type="radio" name="attributes[property_type]" value="brf" {% if cart.attributes.property_type == 'brf' %}checked{% endif %}> Housing association (BRF + apartment no.)
                    </label>
                  </div>
                </div>
                <label class="vk__label" id="vk-fastig-wrap">Property designation <span class="vk__req">*</span>
                  <input type="text" name="attributes[fastighetsbeteckning]" class="vk__input" value="{{ cart.attributes.fastighetsbeteckning }}" placeholder="E.g. Solna 1:23">
                </label>
                <label class="vk__checkbox-label">
                  <input type="checkbox" name="attributes[rot_consent]" value="yes" {% if cart.attributes.rot_consent == 'yes' %}checked{% endif %} required class="vk__checkbox">
                  I confirm that I am entitled to ROT deduction for this installation. If Skatteverket partially or fully rejects the application, I agree to pay the remaining amount.
                  <span class="vk__req">*</span>
                </label>
              </div>
            </div>

            {%- comment -%} Step 3 — Delivery address {%- endcomment -%}
            <div class="vk__step">
              <div class="vk__step-header">
                <span class="vk__step-num">3</span>
                <h2 class="vk__step-title">Delivery address</h2>
              </div>
              <div class="vk__delivery-note">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                This is the address where the installation will take place. We handle all delivery ourselves – no separate shipping fee.
              </div>
              <div class="vk__fields">
                <label class="vk__label">Street address <span class="vk__req">*</span>
                  <input type="text" name="attributes[street]" class="vk__input" value="{{ cart.attributes.street }}" required>
                </label>
                <div class="vk__field-row">
                  <label class="vk__label">Postcode <span class="vk__req">*</span>
                    <input type="text" name="attributes[postcode]" class="vk__input" value="{{ cart.attributes.postcode | default: '171 41' }}" required placeholder="171 41">
                  </label>
                  <label class="vk__label">City <span class="vk__req">*</span>
                    <input type="text" name="attributes[city]" class="vk__input" value="{{ cart.attributes.city | default: 'Solna' }}" required placeholder="Solna">
                  </label>
                </div>
                <label class="vk__label">Door code / installation notes (optional)
                  <input type="text" name="attributes[notes]" class="vk__input" value="{{ cart.attributes.notes }}" placeholder="E.g. floor 3, corner house, installation location">
                </label>
              </div>
            </div>

            {%- comment -%} Step 4 — Payment {%- endcomment -%}
            <div class="vk__step">
              <div class="vk__step-header">
                <span class="vk__step-num">4</span>
                <h2 class="vk__step-title">Payment method</h2>
              </div>
              <div class="vk__payment-options">
                <label class="vk__payment-opt vk__payment-opt--selected">
                  <input type="radio" name="attributes[payment_method]" value="klarna" checked>
                  <div class="vk__payment-opt-inner">
                    <span class="vk__payment-name">Klarna <span class="vk__payment-badge">POPULAR</span></span>
                    <span class="vk__payment-desc">Pay now, in 30 days, or split the payment at checkout.</span>
                  </div>
                </label>
                <label class="vk__payment-opt">
                  <input type="radio" name="attributes[payment_method]" value="lf_12">
                  <div class="vk__payment-opt-inner">
                    <span class="vk__payment-name">Länsförsäkringar Finans – 12 months</span>
                    <span class="vk__payment-desc">Approx. {{ cart.total_price | divided_by: 1200 | round }} kr/month. Final cost and interest determined by Länsförsäkringar Finans.</span>
                  </div>
                </label>
                <label class="vk__payment-opt">
                  <input type="radio" name="attributes[payment_method]" value="lf_24">
                  <div class="vk__payment-opt-inner">
                    <span class="vk__payment-name">Länsförsäkringar Finans – 24 months</span>
                    <span class="vk__payment-desc">Approx. {{ cart.total_price | divided_by: 2400 | round }} kr/month. Final cost and interest determined by Länsförsäkringar Finans.</span>
                  </div>
                </label>
                <label class="vk__payment-opt">
                  <input type="radio" name="attributes[payment_method]" value="lf_36">
                  <div class="vk__payment-opt-inner">
                    <span class="vk__payment-name">Länsförsäkringar Finans – 36 months</span>
                    <span class="vk__payment-desc">Approx. {{ cart.total_price | divided_by: 3600 | round }} kr/month. Final cost and interest determined by Länsförsäkringar Finans.</span>
                  </div>
                </label>
              </div>
              <p class="vk__payment-footer">When you click "Proceed to Klarna" you will be redirected to secure payment. No shipping costs – complete installation included.</p>
            </div>

            <input type="hidden" name="checkout" value="1">
          {% endform %}
        </div>

        {%- comment -%} RIGHT COLUMN — order summary {%- endcomment -%}
        <div class="vk__right">
          <div class="vk__summary">
            <h2 class="vk__summary-title">Your order</h2>

            {% for item in cart.items %}
              <div class="vk__summary-item">
                <div class="vk__summary-img-wrap">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.product.title }}" class="vk__summary-img">
                  {% else %}
                    <div class="vk__summary-img-placeholder">
                      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg>
                    </div>
                  {% endif %}
                </div>
                <div class="vk__summary-item-info">
                  <span class="vk__summary-item-title">{{ item.product.title }}</span>
                  <span class="vk__summary-item-qty">Qty: {{ item.quantity }}</span>
                </div>
                <div class="vk__summary-item-prices">
                  {% if item.original_price > item.final_price %}
                    <span class="vk__summary-compare">{{ item.original_price | times: item.quantity | money }}</span>
                  {% endif %}
                  <span class="vk__summary-price">{{ item.final_price | times: item.quantity | money }}</span>
                </div>
              </div>
            {% endfor %}

            <div class="vk__summary-lines">
              <div class="vk__summary-line">
                <span>Subtotal</span>
                <span>{{ cart.original_total_price | money }}</span>
              </div>
              {% assign rot_amount = cart.total_price | times: 15 | divided_by: 100 %}
              <div class="vk__summary-line vk__summary-line--discount">
                <span>ROT deduction (15%)</span>
                <span>−{{ rot_amount | money }}</span>
              </div>
              <div class="vk__summary-line">
                <span>Installation</span>
                <span class="vk__summary-included">Included</span>
              </div>
              <div class="vk__summary-line">
                <span>Shipping</span>
                <span class="vk__summary-included">0 kr</span>
              </div>
            </div>

            <div class="vk__summary-total">
              <span>Total after ROT</span>
              <span class="vk__summary-total-price">{{ cart.total_price | money }}</span>
            </div>
            <p class="vk__summary-vat">Incl. VAT</p>

            <button type="submit" form="vk-form" class="vk__klarna-btn">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              Proceed to Klarna
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>

            <ul class="vk__trust-list">
              <li>
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                Complete installation included
              </li>
              <li>
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                ROT deduction available
              </li>
              <li>
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                5-year installation warranty
              </li>
              <li>
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#19aaf8" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                We handle all delivery
              </li>
            </ul>

            <a href="/pages/shop" class="vk__continue">← Continue shopping</a>
          </div>
        </div>

      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .vk {
    background: #f5f9fc;
    padding: 48px 0 80px;
    min-height: 70vh;
  }
  .vk__container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .vk__empty {
    text-align: center;
    padding: 80px 0;
  }
  .vk__empty h1 { font-size: 28px; font-weight: 700; color: #224466; margin-bottom: 24px; }
  .vk__empty-btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    background: #19aaf8;
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
  }
  .vk__layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 32px;
    align-items: start;
  }
  .vk__heading {
    font-size: 32px;
    font-weight: 800;
    color: #224466;
    margin-bottom: 6px;
  }
  .vk__subheading {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: #5b6474;
    margin-bottom: 32px;
  }

  /* Steps */
  .vk__step {
    background: #fff;
    border-radius: 14px;
    border: 1px solid #e6e8ef;
    padding: 24px;
    margin-bottom: 16px;
  }
  .vk__step-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .vk__step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #19aaf8;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .vk__step-title {
    font-size: 18px;
    font-weight: 700;
    color: #224466;
  }

  /* Fields */
  .vk__fields { display: flex; flex-direction: column; gap: 16px; }
  .vk__field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .vk__label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: #2a2f3d;
  }
  .vk__req { color: #e53e3e; }
  .vk__input {
    border: 1.5px solid #dde1ec;
    border-radius: 8px;
    padding: 11px 14px;
    font-size: 15px;
    font-family: inherit;
    color: #224466;
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }
  .vk__input:focus { border-color: #19aaf8; }
  .vk__hint {
    font-size: 12px;
    color: #5b6474;
    margin-top: -2px;
  }

  /* Radio buttons */
  .vk__radio-row { display: flex; flex-direction: column; gap: 10px; margin-top: 6px; }
  .vk__radio {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border: 1.5px solid #dde1ec;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    color: #2a2f3d;
    transition: border-color 0.15s, background 0.15s;
  }
  .vk__radio--selected,
  .vk__radio:has(input:checked) { border-color: #19aaf8; background: #e8f6fe; }
  .vk__radio input[type="radio"] { accent-color: #19aaf8; }

  /* Checkbox */
  .vk__checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: #5b6474;
    line-height: 1.5;
    cursor: pointer;
  }
  .vk__checkbox { margin-top: 2px; accent-color: #19aaf8; flex-shrink: 0; }

  /* Notes */
  .vk__rot-note,
  .vk__delivery-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #e8f6fe;
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 13px;
    color: #224466;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  /* Payment options */
  .vk__payment-options { display: flex; flex-direction: column; gap: 10px; }
  .vk__payment-opt {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border: 1.5px solid #dde1ec;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .vk__payment-opt--selected,
  .vk__payment-opt:has(input:checked) { border-color: #19aaf8; background: #e8f6fe; }
  .vk__payment-opt input[type="radio"] { margin-top: 3px; accent-color: #19aaf8; flex-shrink: 0; }
  .vk__payment-opt-inner { display: flex; flex-direction: column; gap: 3px; }
  .vk__payment-name { font-size: 15px; font-weight: 600; color: #224466; display: flex; align-items: center; gap: 8px; }
  .vk__payment-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: #19aaf8;
    color: #fff;
    padding: 2px 7px;
    border-radius: 4px;
  }
  .vk__payment-desc { font-size: 13px; color: #5b6474; }
  .vk__payment-footer { font-size: 12px; color: #5b6474; margin-top: 16px; line-height: 1.5; }

  /* Right column — summary */
  .vk__summary {
    background: #fff;
    border-radius: 14px;
    border: 1px solid #e6e8ef;
    padding: 24px;
    position: sticky;
    top: 88px;
  }
  .vk__summary-title {
    font-size: 17px;
    font-weight: 700;
    color: #224466;
    margin-bottom: 20px;
  }
  .vk__summary-item {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f0f2f7;
  }
  .vk__summary-img-wrap {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    background: #f5f9fc;
    border: 1px solid #e6e8ef;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vk__summary-img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
  .vk__summary-img-placeholder { color: #c7d0de; }
  .vk__summary-item-info { display: flex; flex-direction: column; gap: 2px; }
  .vk__summary-item-title { font-size: 14px; font-weight: 600; color: #224466; }
  .vk__summary-item-qty { font-size: 12px; color: #5b6474; }
  .vk__summary-item-prices { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .vk__summary-compare { font-size: 12px; color: #a0aab4; text-decoration: line-through; }
  .vk__summary-price { font-size: 14px; font-weight: 700; color: #224466; }

  .vk__summary-lines { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
  .vk__summary-line {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: #5b6474;
  }
  .vk__summary-line--discount span:last-child { color: #e53e3e; font-weight: 600; }
  .vk__summary-included { color: #19aaf8; font-weight: 600; }

  .vk__summary-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0 4px;
    border-top: 2px solid #e6e8ef;
    font-size: 16px;
    font-weight: 700;
    color: #224466;
  }
  .vk__summary-total-price { font-size: 22px; font-weight: 800; color: #19aaf8; }
  .vk__summary-vat { font-size: 12px; color: #5b6474; margin-bottom: 20px; }

  .vk__klarna-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 15px 20px;
    background: #19aaf8;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
    margin-bottom: 16px;
    font-family: inherit;
  }
  .vk__klarna-btn:hover { background: #224466; }

  .vk__trust-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .vk__trust-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #5b6474;
  }

  .vk__continue {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #5b6474;
    text-decoration: none;
    border-top: 1px solid #f0f2f7;
    padding-top: 16px;
    transition: color 0.15s;
  }
  .vk__continue:hover { color: #224466; }

  @media (max-width: 900px) {
    .vk__layout { grid-template-columns: 1fr; }
    .vk__summary { position: static; }
  }
  @media (max-width: 600px) {
    .vk__container { padding: 0 16px; }
    .vk__field-row { grid-template-columns: 1fr; }
    .vk__heading { font-size: 24px; }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var radios = document.querySelectorAll('.vk__payment-opt input[type="radio"]');
    radios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        document.querySelectorAll('.vk__payment-opt').forEach(function(opt) {
          opt.classList.remove('vk__payment-opt--selected');
        });
        radio.closest('.vk__payment-opt').classList.add('vk__payment-opt--selected');
      });
    });

    var propRadios = document.querySelectorAll('.vk__radio input[type="radio"]');
    propRadios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        document.querySelectorAll('.vk__radio').forEach(function(r) {
          r.classList.remove('vk__radio--selected');
        });
        radio.closest('.vk__radio').classList.add('vk__radio--selected');
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Checkout (Kassa)",
  "settings": [],
  "presets": [{ "name": "Checkout (Kassa)" }]
}
{% endschema %}
