  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact_column",
      "name": "Contact column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Kontakt"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "020 – 89 91 19"
        },
        {
          "type": "text",
