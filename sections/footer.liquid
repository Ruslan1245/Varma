    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "Trust badge 3",
      "default": "Swedish-owned"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Certifierad installation, service och reparation av värmepumpar i hela Stockholms län. Auktoriserad partner för Toshiba, Daikin och Mitsubishi."
    },
    {
      "type": "text",
      "id": "badge1",
