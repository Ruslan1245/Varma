<footer class="v-footer">
  <div class="v-footer__main">
    <div class="v-footer__container">
      <div class="v-footer__brand">
        <a href="{{ routes.root_url }}" class="v-footer__logo" aria-label="{{ shop.name }}">
          <span class="v-footer__logo-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
          </span>
          <span class="v-footer__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        </a>
        <p class="v-footer__tagline">{{ section.settings.tagline }}</p>
        <div class="v-footer__badges">
          {% if section.settings.badge1 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge1 }}</span>
          {% endif %}
          {% if section.settings.badge2 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge2 }}</span>
          {% endif %}
          {% if section.settings.badge3 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge3 }}</span>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'link_column' %}
          <div class="v-footer__col" {{ block.shopify_attributes }}>
            <h4 class="v-footer__col-title">{{ block.settings.title }}</h4>
            <ul class="v-footer__links">
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}" class="v-footer__link">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        {% if block.type == 'contact_column' %}
          <div class="v-footer__col" {{ block.shopify_attributes }}>
            <h4 class="v-footer__col-title">{{ block.settings.title }}</h4>
            <ul class="v-footer__links">
              {% if block.settings.phone != blank %}
                <li><a href="tel:{{ block.settings.phone | remove: ' ' | remove: '-' }}" class="v-footer__link">{{ block.settings.phone }}</a></li>
              {% endif %}
              {% if block.settings.email != blank %}
                <li><a href="mailto:{{ block.settings.email }}" class="v-footer__link">{{ block.settings.email }}</a></li>
              {% endif %}
              {% if block.settings.address1 != blank %}
                <li class="v-footer__link">{{ block.settings.address1 }}</li>
              {% endif %}
              {% if block.settings.address2 != blank %}
                <li class="v-footer__link">{{ block.settings.address2 }}</li>
              {% endif %}
            </ul>
            <div class="v-footer__social">
              {% if block.settings.facebook_url != blank %}
                <a href="{{ block.settings.facebook_url }}" class="v-footer__social-link" aria-label="Facebook" rel="noopener">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              {% endif %}
              {% if block.settings.instagram_url != blank %}
                <a href="{{ block.settings.instagram_url }}" class="v-footer__social-link" aria-label="Instagram" rel="noopener">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              {% endif %}
              {% if block.settings.linkedin_url != blank %}
                <a href="{{ block.settings.linkedin_url }}" class="v-footer__social-link" aria-label="LinkedIn" rel="noopener">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if section.settings.service_areas != blank %}
    <div class="v-footer__areas">
      <div class="v-footer__container">
        <span class="v-footer__areas-label">SERVICEOMRÅDEN I STORSTOCKHOLM</span>
        <div class="v-footer__areas-list">
          {% assign areas = section.settings.service_areas | split: ',' %}
          {% for area in areas %}
            <span class="v-footer__area">{{ area | strip }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <div class="v-footer__bottom">
    <div class="v-footer__container">
      <span class="v-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.company_legal | default: shop.name }}
      </span>
      <div class="v-footer__bottom-links">
        {% for link in section.settings.bottom_menu.links %}
          <a href="{{ link.url }}" class="v-footer__bottom-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .v-footer {
    background: #0F172A;
    color: #94A3B8;
  }
  .v-footer__main {
    padding: 56px 0 48px;
  }
  .v-footer__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 40px;
  }
  .v-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .v-footer__logo-icon {
    width: 34px;
    height: 34px;
    background: #2563EB;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-footer__logo-text {
    font-size: 18px;
    font-weight: 700;
    color: white;
  }
  .v-footer__tagline {
    font-size: 14px;
    line-height: 1.65;
    color: #64748B;
    margin-bottom: 20px;
  }
  .v-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .v-footer__badge {
    background: #1E293B;
    border: 1px solid #334155;
    color: #94A3B8;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 6px;
  }
  .v-footer__col-title {
    font-size: 14px;
    font-weight: 700;
    color: white;
    margin-bottom: 16px;
  }
  .v-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v-footer__link {
    font-size: 14px;
    color: #64748B;
    text-decoration: none;
    transition: color 0.15s;
  }
  .v-footer__link:hover { color: #CBD5E1; }
  .v-footer__social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .v-footer__social-link {
    width: 36px;
    height: 36px;
    background: #1E293B;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748B;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .v-footer__social-link:hover {
    background: #2563EB;
    color: white;
  }
  .v-footer__areas {
    border-top: 1px solid #1E293B;
    padding: 24px 0;
  }
  .v-footer__areas .v-footer__container {
    display: block;
  }
  .v-footer__areas-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #475569;
    display: block;
    margin-bottom: 12px;
  }
  .v-footer__areas-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
  }
  .v-footer__area {
    font-size: 14px;
    color: #64748B;
  }
  .v-footer__bottom {
    border-top: 1px solid #1E293B;
    padding: 20px 0;
  }
  .v-footer__bottom .v-footer__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v-footer__copyright {
    font-size: 13px;
    color: #475569;
  }
  .v-footer__bottom-links {
    display: flex;
    gap: 20px;
  }
  .v-footer__bottom-link {
    font-size: 13px;
    color: #475569;
    text-decoration: none;
    transition: color 0.15s;
  }
  .v-footer__bottom-link:hover { color: #94A3B8; }
  @media (max-width: 900px) {
    .v-footer__container { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .v-footer__container { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact_column",
      "name": "Contact column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Kontakt"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "020 – 89 91 19"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "info@varmaenergy.se"
        },
        {
          "type": "text",
          "id": "address1",
          "label": "Address 1",
          "default": "Esplanaden 13, Sundbyberg"
        },
        {
          "type": "text",
          "id": "address2",
          "label": "Address 2",
          "default": "Sjöflygvägen 35, Täby"
        },
        {
          "type": "url",
          "id": "facebook_url",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn URL"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Varma"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Certifierad installation, service och reparation av värmepumpar i hela Stockholms län. Auktoriserad partner för Toshiba, Daikin och Mitsubishi."
    },
    {
      "type": "text",
      "id": "badge1",
      "label": "Badge 1",
      "default": "F-gas cert."
    },
    {
      "type": "text",
      "id": "badge2",
      "label": "Badge 2",
      "default": "Reco topp-10"
    },
    {
      "type": "text",
      "id": "badge3",
      "label": "Badge 3",
      "default": "ISO 9001"
    },
    {
      "type": "text",
      "id": "service_areas",
      "label": "Service areas (comma-separated)",
      "default": "Stockholm, Sundbyberg, Solna, Danderyd, Täby, Nacka, Lidingö, Huddinge, Sollentuna, Järfälla"
    },
    {
      "type": "text",
      "id": "company_legal",
      "label": "Legal company name",
      "default": "VARMA Energy AB · Org.nr 559000–0000"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom links menu"
    }
  ]
}
{% endschema %}
