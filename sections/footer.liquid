<footer class="v-footer full-width">
  <div class="v-footer__main">
    <div class="v-footer__container">
      
      <!-- ЛІВА КОЛОНКА: Логотип + бейджі + текст -->
      <div class="v-footer__brand">
        <a href="{{ routes.root_url }}" class="v-footer__logo" aria-label="{{ shop.name }}">
          <span class="v-footer__logo-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
          </span>
          <span class="v-footer__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        </a>
        
        <!-- БЕЙДЖІ БЕЗПОСЕРЕДНЬО ПІД ЛОГОТИПОМ -->
        <div class="v-footer__trust-badges">
          <span>{{ section.settings.trust_badge_1 | default: 'Authorized' }}</span>
          <span>·</span>
          <span>{{ section.settings.trust_badge_2 | default: 'Certified' }}</span>
          <span>·</span>
          <span>{{ section.settings.trust_badge_3 | default: 'Swedish-owned' }}</span>
        </div>
        
        <p class="v-footer__tagline">{{ section.settings.tagline }}</p>
        
        <div class="v-footer__badges">
          {% if section.settings.badge1 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge1 }}</span>
          {% endif %}
          {% if section.settings.badge2 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge2 }}</span>
          {% endif %}
          {% if section.settings.badge3 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge3 }}</span>
          {% endif %}
        </div>
      </div>

      <!-- ПРАВА КОЛОНКА: SERVICE AREAS + контент -->
      <div class="v-footer__areas">
        <span class="v-footer__areas-label">{{ section.settings.areas_label | default: 'SERVICE AREAS' }}</span>
        <p class="v-footer__areas-subtitle">{{ section.settings.areas_subtitle | default: 'Heat pump services in Greater Stockholm' }}</p>
        <div class="v-footer__areas-list">
          {% assign areas = section.settings.service_areas | split: ',' %}
          {% for area in areas %}
            {% assign area_slug = area | strip | handleize %}
            <a href="/pages/{{ area_slug }}" class="v-footer__area">{{ area | strip }}</a>
          {% endfor %}
        </div>
        <span class="v-footer__areas-count">{{ section.settings.areas_count | default: '10 cities' }}</span>
      </div>

      <!-- КОНТАКТНА КОЛОНКА (опціонально, якщо потрібна) -->
      <div class="v-footer__contact">
        <h4 class="v-footer__col-title">Kontakt</h4>
        <ul class="v-footer__links">
          <li><a href="tel:020899119" class="v-footer__link">020 – 89 91 19</a></li>
          <li><a href="mailto:info@varmaenergy.se" class="v-footer__link">info@varmaenergy.se</a></li>
          <li class="v-footer__link">Esplanaden 13, Sundbyberg</li>
          <li class="v-footer__link">Sjöfryggvägen 35, Täby</li>
        </ul>
      </div>

    </div>
  </div>

  <!-- НИЖНІЙ РЯД -->
  <div class="v-footer__bottom">
    <div class="v-footer__container">
      <span class="v-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.company_legal | default: shop.name }}
      </span>
      <div class="v-footer__bottom-links">
        {% for link in section.settings.bottom_menu.links %}
          <a href="{{ link.url }}" class="v-footer__bottom-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .v-footer {
    background: #1a3b3f;
    color: rgba(255,255,255,0.72);
  }
  .v-footer__main {
    padding: 56px 0 48px;
  }
  .v-footer__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
  }
  
  .v-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 12px;
  }
  .v-footer__logo-icon {
    width: 34px;
    height: 34px;
    background: #19aaf8;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-footer__logo-text {
    font-size: 24px;
    font-weight: 700;
    color: white;
    letter-spacing: 1px;
  }
  
  /* БЕЙДЖІ БЕЗПОСЕРЕДНЬО ПІД ЛОГОТИПОМ */
  .v-footer__trust-badges {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
    letter-spacing: 0.3px;
  }
  .v-footer__trust-badges span {
    display: inline-block;
  }
  
  .v-footer__tagline {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255,255,255,0.72);
    margin-bottom: 20px;
    max-width: 320px;
  }
  .v-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .v-footer__badge {
    background: #2c555a;
    border: none;
    color: rgba(255,255,255,0.9);
    font-size: 13px;
    font-weight: 500;
    padding: 4px 14px;
    border-radius: 20px;
  }
  
  /* SERVICE AREAS */
  .v-footer__areas {
    display: flex;
    flex-direction: column;
  }
  .v-footer__areas-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #8bb3b8;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
  }
  .v-footer__areas-subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    margin: 0 0 12px 0;
  }
  .v-footer__areas-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 24px;
  }
  .v-footer__area {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: color 0.15s;
    border-bottom: 1px dotted transparent;
  }
  .v-footer__area:hover {
    color: #ffffff;
    border-bottom-color: #ffffff;
  }
  .v-footer__areas-count {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-top: 8px;
  }
  
  /* КОНТАКТИ */
  .v-footer__col-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #8bb3b8;
    margin-bottom: 16px;
  }
  .v-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v-footer__link {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.5;
  }
  .v-footer__link:hover { 
    color: #ffffff;
    text-decoration: underline;
  }
  
  /* НИЖНІЙ РЯД */
  .v-footer__bottom {
    border-top: 1px solid #3e676c;
    padding: 20px 0;
  }
  .v-footer__bottom .v-footer__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v-footer__copyright {
    font-size: 14px;
    color: #a0c2c7;
  }
  .v-footer__bottom-links {
    display: flex;
    gap: 25px;
  }
  .v-footer__bottom-link {
    font-size: 14px;
    color: #a0c2c7;
    text-decoration: none;
    transition: color 0.15s;
  }
  .v-footer__bottom-link:hover { 
    color: #ffffff;
    text-decoration: underline;
  }
  
  /* АДАПТИВ */
  @media (max-width: 900px) {
    .v-footer__container { 
      grid-template-columns: 1fr 1fr; 
    }
  }
  @media (max-width: 600px) {
    .v-footer__container { 
      grid-template-columns: 1fr; 
      padding: 0 20px;
    }
    .v-footer__main {
      padding: 40px 0 32px;
    }
    .v-footer__bottom .v-footer__container {
      flex-direction: column;
      align-items: flex-start;
    }
    .v-footer__bottom-links {
      flex-wrap: wrap;
      gap: 12px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Varma"
    },
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "Trust badge 1",
      "default": "Authorized"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "Trust badge 2",
      "default": "Certified"
    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "Trust badge 3",
      "default": "Swedish-owned"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Certifierad installation, service och reparation av värmepumpar i hela Stockholms län. Auktoriserad partner för Toshiba, Daikin och Mitsubishi."
    },
    {
      "type": "text",
      "id": "badge1",
      "label": "Badge 1",
      "default": "F-gas cert."
    },
    {
      "type": "text",
      "id": "badge2",
      "label": "Badge 2",
      "default": "Reco topp-10"
    },
    {
      "type": "text",
      "id": "badge3",
      "label": "Badge 3",
      "default": "ISO 9001"
    },
    {
      "type": "text",
      "id": "areas_label",
      "label": "Service areas label",
      "default": "SERVICE AREAS"
    },
    {
      "type": "text",
      "id": "areas_subtitle",
      "label": "Service areas subtitle",
      "default": "Heat pump services in Greater Stockholm"
    },
    {
      "type": "text",
      "id": "service_areas",
      "label": "Service areas (comma-separated)",
      "default": "Stockholm, Sundbyberg, Solna, Danderyd, Täby, Nacka, Lidingö, Huddinge, Sollentuna, Järfälla"
    },
    {
      "type": "text",
      "id": "areas_count",
      "label": "Areas count text",
      "default": "10 cities"
    },
    {
      "type": "text",
      "id": "company_legal",
      "label": "Legal company name",
      "default": "VARMA Energy AB · Org.nr 559000-0000"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom links menu"
    }
  ]
}
{% endschema %}