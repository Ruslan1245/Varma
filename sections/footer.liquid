          "label": "Email",
          "default": "info@varmaenergy.se"
        },
        {
          "type": "text",
          "id": "address1",
          "label": "Address 1",
          "default": "Esplanaden 13, Sundbyberg"
        },
        {
          "type": "text",
          "id": "address2",
          "label": "Address 2",
          "default": "Sjöfryggvägen 35, Täby"
        },
        {
          "type": "url",
          "id": "facebook_url",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn URL"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
