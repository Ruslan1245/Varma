<footer class="v-footer full-width">

  <!-- ── MAIN 4-column grid ── -->
  <div class="v-footer__main">
    <div class="v-footer__inner">

      <!-- Col 1: Brand -->
      <div class="v-footer__brand">
        <a href="{{ routes.root_url }}" class="v-footer__logo" aria-label="{{ shop.name }}">
          <span class="v-footer__logo-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
          </span>
          <span class="v-footer__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        </a>

        <p class="v-footer__tagline">{{ section.settings.tagline }}</p>

        <div class="v-footer__badges">
          {% if section.settings.badge1 != blank %}<span class="v-footer__badge">{{ section.settings.badge1 }}</span>{% endif %}
          {% if section.settings.badge2 != blank %}<span class="v-footer__badge">{{ section.settings.badge2 }}</span>{% endif %}
          {% if section.settings.badge3 != blank %}<span class="v-footer__badge">{{ section.settings.badge3 }}</span>{% endif %}
        </div>
      </div>

      <!-- Col 2: Produkter -->
      <div class="v-footer__col">
        <h4 class="v-footer__col-title">{{ section.settings.products_title | default: 'Products' }}</h4>
        <ul class="v-footer__links">
          {% for link in linklists[section.settings.products_menu].links %}
            <li><a href="{{ link.url }}" class="v-footer__link">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Col 3: Tjänster -->
      <div class="v-footer__col">
        <h4 class="v-footer__col-title">{{ section.settings.services_title | default: 'Services' }}</h4>
        <ul class="v-footer__links">
          {% for link in linklists[section.settings.services_menu].links %}
            <li><a href="{{ link.url }}" class="v-footer__link">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Col 4: Kontakt -->
      <div class="v-footer__col">
        <h4 class="v-footer__col-title">{{ section.settings.contact_title | default: 'Contact' }}</h4>
        <ul class="v-footer__links">
          {% if section.settings.phone != blank %}
            <li><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '–' | remove: '-' }}" class="v-footer__link">{{ section.settings.phone }}</a></li>
          {% endif %}
          {% if section.settings.email != blank %}
            <li><a href="mailto:{{ section.settings.email }}" class="v-footer__link">{{ section.settings.email }}</a></li>
          {% endif %}
          {% if section.settings.address1 != blank %}
            <li class="v-footer__link">{{ section.settings.address1 }}</li>
          {% endif %}
          {% if section.settings.address2 != blank %}
            <li class="v-footer__link">{{ section.settings.address2 }}</li>
          {% endif %}
        </ul>

        <div class="v-footer__social">
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="v-footer__social-btn" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="v-footer__social-btn" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if section.settings.linkedin_url != blank %}
            <a href="{{ section.settings.linkedin_url }}" class="v-footer__social-btn" aria-label="LinkedIn" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

    </div>
  </div>

  <!-- ── SERVICE AREAS — below the columns ── -->
  <div class="v-footer__areas-row">
    <div class="v-footer__container">
      <span class="v-footer__areas-label">{{ section.settings.areas_label | default: 'SERVICE AREAS IN GREATER STOCKHOLM' }}</span>
      <div class="v-footer__areas-list">
        {% assign areas = section.settings.service_areas | split: ',' %}
        {% for area in areas %}
          {% assign area_slug = area | strip | handleize %}
          <a href="/pages/{{ area_slug }}" class="v-footer__area">{{ area | strip }}</a>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="v-footer__bottom">
    <div class="v-footer__container">
      <span class="v-footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.company_legal | default: shop.name }}</span>
      <div class="v-footer__bottom-links">
        {% for link in linklists[section.settings.bottom_menu].links %}
          <a href="{{ link.url }}" class="v-footer__bottom-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>

</footer>

{% stylesheet %}
  .v-footer {
    background: #0a0f1a;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ── Main grid ── */
  .v-footer__main {
    padding: 56px 0 48px;
  }
  .v-footer__inner {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 48px;
  }

  /* ── Brand column ── */
  .v-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .v-footer__logo-icon {
    width: 32px;
    height: 32px;
    background: #19aaf8;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-footer__logo-text {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.5px;
  }
  .v-footer__tagline {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 20px;
    max-width: 280px;
  }
  .v-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .v-footer__badge {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    padding: 4px 14px;
    white-space: nowrap;
  }

  /* ── Nav columns ── */
  .v-footer__col-title {
    font-size: 15px;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 16px;
  }
  .v-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v-footer__link {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.5;
    display: block;
  }
  a.v-footer__link:hover { color: #ffffff; }

  /* ── Social icons ── */
  .v-footer__social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .v-footer__social-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .v-footer__social-btn:hover {
    border-color: rgba(255, 255, 255, 0.6);
    color: #ffffff;
  }

  /* ── Service areas row ── */
  .v-footer__areas-row {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 24px 0;
  }
  .v-footer__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .v-footer__areas-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 12px;
  }
  .v-footer__areas-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 0;
  }
  .v-footer__area {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.15s;
    padding-right: 24px;
  }
  .v-footer__area:hover { color: #ffffff; }

  /* ── Bottom bar ── */
  .v-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 20px 0;
  }
  .v-footer__bottom .v-footer__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v-footer__copyright {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }
  .v-footer__bottom-links {
    display: flex;
    gap: 24px;
  }
  .v-footer__bottom-link {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s;
  }
  .v-footer__bottom-link:hover { color: #ffffff; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .v-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px 32px;
    }
    .v-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .v-footer__inner {
      grid-template-columns: 1fr 1fr;
      padding: 0 20px;
      gap: 32px 24px;
    }
    .v-footer__main { padding: 40px 0 32px; }
    .v-footer__container { padding: 0 20px; }
    .v-footer__bottom .v-footer__container {
      flex-direction: column;
      align-items: flex-start;
    }
    .v-footer__bottom-links { flex-wrap: wrap; gap: 10px 20px; }
  }
{% endstylesheet %}

