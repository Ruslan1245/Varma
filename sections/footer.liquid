<footer class="v-footer full-width">
  <div class="v-footer__main">
    <div class="v-footer__container">
      <div class="v-footer__brand">
        <a href="{{ routes.root_url }}" class="v-footer__logo" aria-label="{{ shop.name }}">
          <span class="v-footer__logo-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2l1.5 3.5L17 4l-1.5 3.5L19 9l-3.5 1.5L17 14l-3.5-1.5L12 16l-1.5-3.5L7 14l1.5-3.5L5 9l3.5-1.5L7 4l3.5 1.5L12 2z"/></svg>
          </span>
          <span class="v-footer__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        </a>
        
        <!-- Бейджі "Authorized · Certified · Swedish-owned" -->
        <div class="v-footer__trust-badges">
          <span>{{ section.settings.trust_badge_1 | default: 'Authorized' }}</span>
          <span>·</span>
          <span>{{ section.settings.trust_badge_2 | default: 'Certified' }}</span>
          <span>·</span>
          <span>{{ section.settings.trust_badge_3 | default: 'Swedish-owned' }}</span>
        </div>
        
        <p class="v-footer__tagline">{{ section.settings.tagline }}</p>
        
        <div class="v-footer__badges">
          {% if section.settings.badge1 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge1 }}</span>
          {% endif %}
          {% if section.settings.badge2 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge2 }}</span>
          {% endif %}
          {% if section.settings.badge3 != blank %}
            <span class="v-footer__badge">{{ section.settings.badge3 }}</span>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'link_column' %}
          <div class="v-footer__col" {{ block.shopify_attributes }}>
            <h4 class="v-footer__col-title">{{ block.settings.title }}</h4>
            <ul class="v-footer__links">
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}" class="v-footer__link">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        {% if block.type == 'contact_column' %}
          <div class="v-footer__col" {{ block.shopify_attributes }}>
            <h4 class="v-footer__col-title">{{ block.settings.title }}</h4>
            <ul class="v-footer__links">
              {% if block.settings.phone != blank %}
                <li><a href="tel:{{ block.settings.phone | remove: ' ' | remove: '-' | remove: '–' }}" class="v-footer__link">{{ block.settings.phone }}</a></li>
              {% endif %}
              {% if block.settings.email != blank %}
                <li><a href="mailto:{{ block.settings.email }}" class="v-footer__link">{{ block.settings.email }}</a></li>
              {% endif %}
              {% if block.settings.address1 != blank %}
                <li class="v-footer__link">{{ block.settings.address1 }}</li>
              {% endif %}
              {% if block.settings.address2 != blank %}
                <li class="v-footer__link">{{ block.settings.address2 }}</li>
              {% endif %}
            </ul>
            <div class="v-footer__social">
              {% if block.settings.facebook_url != blank %}
                <a href="{{ block.settings.facebook_url }}" class="v-footer__social-link" aria-label="Facebook" rel="noopener">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              {% endif %}
              {% if block.settings.instagram_url != blank %}
                <a href="{{ block.settings.instagram_url }}" class="v-footer__social-link" aria-label="Instagram" rel="noopener">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              {% endif %}
              {% if block.settings.linkedin_url != blank %}
                <a href="{{ block.settings.linkedin_url }}" class="v-footer__social-link" aria-label="LinkedIn" rel="noopener">
                  <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Секція з містами та контентом справа -->
  {% if section.settings.service_areas != blank %}
    <div class="v-footer__areas">
      <div class="v-footer__container v-footer__areas-container">
        <div class="v-footer__areas-left">
          <span class="v-footer__areas-label">{{ section.settings.areas_label | default: 'SERVICE AREAS' }}</span>
          <p class="v-footer__areas-subtitle">{{ section.settings.areas_subtitle | default: 'Heat pump services in Greater Stockholm' }}</p>
          <div class="v-footer__areas-list">
            {% assign areas = section.settings.service_areas | split: ',' %}
            {% for area in areas %}
              {% assign area_slug = area | strip | handleize %}
              <a href="/pages/{{ area_slug }}" class="v-footer__area">{{ area | strip }}</a>
            {% endfor %}
          </div>
          <span class="v-footer__areas-count">{{ section.settings.areas_count | default: '10 cities' }}</span>
        </div>
        <div class="v-footer__areas-right">
          <!-- Бейджі "Authorized · Certified · Swedish-owned" -->
          <div class="v-footer__trust-badges-large">
            <span>{{ section.settings.trust_badge_1 | default: 'Authorized' }}</span>
            <span>·</span>
            <span>{{ section.settings.trust_badge_2 | default: 'Certified' }}</span>
            <span>·</span>
            <span>{{ section.settings.trust_badge_3 | default: 'Swedish-owned' }}</span>
          </div>
          <p class="v-footer__areas-tagline">{{ section.settings.areas_tagline | default: "Stockholm's smartest experts in heating and cooling." }}</p>
          <div class="v-footer__areas-badges">
            <span class="v-footer__area-badge">F-gas cert.</span>
            <span class="v-footer__area-badge">Reco topp-10</span>
            <span class="v-footer__area-badge">ISO 9001</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="v-footer__bottom">
    <div class="v-footer__container">
      <span class="v-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.company_legal | default: shop.name }}
      </span>
      <div class="v-footer__bottom-links">
        {% for link in section.settings.bottom_menu.links %}
          <a href="{{ link.url }}" class="v-footer__bottom-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .v-footer {
    background: #1a3b3f;
    color: rgba(255,255,255,0.72);
  }
  .v-footer__main {
    padding: 56px 0 48px;
  }
  .v-footer__container {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 40px;
  }
  .v-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 12px;
  }
  .v-footer__logo-icon {
    width: 34px;
    height: 34px;
    background: #19aaf8;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .v-footer__logo-text {
    font-size: 24px;
    font-weight: 700;
    color: white;
    letter-spacing: 1px;
  }
  .v-footer__trust-badges {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
    letter-spacing: 0.3px;
  }
  .v-footer__trust-badges span {
    display: inline-block;
  }
  .v-footer__tagline {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255,255,255,0.72);
    margin-bottom: 20px;
    max-width: 320px;
  }
  .v-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .v-footer__badge {
    background: #2c555a;
    border: none;
    color: rgba(255,255,255,0.9);
    font-size: 13px;
    font-weight: 500;
    padding: 4px 14px;
    border-radius: 20px;
  }
  .v-footer__col-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #8bb3b8;
    margin-bottom: 16px;
  }
  .v-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v-footer__link {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.5;
  }
  .v-footer__link:hover { 
    color: #ffffff;
    text-decoration: underline;
  }
  .v-footer__social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .v-footer__social-link {
    width: 36px;
    height: 36px;
    background: #2c555a;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .v-footer__social-link:hover {
    background: #19aaf8;
    color: white;
  }

  /* Секція з містами + контентом справа */
  .v-footer__areas {
    border-top: 1px solid #3e676c;
    padding: 28px 0;
  }
  .v-footer__areas-container {
    display: grid !important;
    grid-template-columns: 1.4fr 1fr !important;
    gap: 40px !important;
  }
  .v-footer__areas-left {
    display: flex;
    flex-direction: column;
  }
  .v-footer__areas-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #8bb3b8;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
  }
  .v-footer__areas-subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    margin: 0 0 12px 0;
  }
  .v-footer__areas-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 24px;
  }
  .v-footer__area {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: color 0.15s;
    border-bottom: 1px dotted transparent;
  }
  .v-footer__area:hover {
    color: #ffffff;
    border-bottom-color: #ffffff;
  }
  .v-footer__areas-count {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-top: 8px;
  }
  .v-footer__areas-right {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .v-footer__trust-badges-large {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
    letter-spacing: 0.3px;
  }
  .v-footer__trust-badges-large span {
    display: inline-block;
  }
  .v-footer__areas-tagline {
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.4;
    margin: 0 0 16px 0;
  }
  .v-footer__areas-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .v-footer__area-badge {
    background: #2c555a;
    color: rgba(255,255,255,0.9);
    font-size: 13px;
    font-weight: 500;
    padding: 4px 14px;
    border-radius: 20px;
  }

  .v-footer__bottom {
    border-top: 1px solid #3e676c;
    padding: 20px 0;
  }
  .v-footer__bottom .v-footer__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v-footer__copyright {
    font-size: 14px;
    color: #a0c2c7;
  }
  .v-footer__bottom-links {
    display: flex;
    gap: 25px;
  }
  .v-footer__bottom-link {
    font-size: 14px;
    color: #a0c2c7;
    text-decoration: none;
    transition: color 0.15s;
  }
  .v-footer__bottom-link:hover { 
    color: #ffffff;
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .v-footer__container { 
      grid-template-columns: 1fr 1fr 1fr; 
    }
    .v-footer__areas-container {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
  }
  @media (max-width: 768px) {
    .v-footer__container { 
      grid-template-columns: 1fr 1fr; 
    }
    .v-footer__areas-list {
      gap: 4px 16px;
    }
    .v-footer__bottom .v-footer__container {
      flex-direction: column;
      align-items: flex-start;
    }
    .v-footer__trust-badges-large {
      font-size: 13px;
    }
    .v-footer__areas-tagline {
      font-size: 16px;
    }
  }
  @media (max-width: 500px) {
    .v-footer__container { 
      grid-template-columns: 1fr; 
      padding: 0 20px;
    }
    .v-footer__main {
      padding: 40px 0 32px;
    }
    .v-footer__areas {
      padding: 20px 0;
    }
    .v-footer__bottom-links {
      flex-wrap: wrap;
      gap: 12px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
