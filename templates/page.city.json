        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "How much does a heat pump cost in Stockholm?",
            "answer": "The price varies by type. Air-to-air starts around 18,000 SEK, air-to-water around 65,000 SEK and ground source 150,000–200,000 SEK including drilling. After ROT deduction (30% of labour) the net cost is significantly lower. We provide a fixed quote with no hidden costs."
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "Do I need a permit for a heat pump in Stockholm?",
            "answer": "Air-to-air and air-to-water pumps generally do not require a building permit but may need approval from the housing association. Ground source drilling requires a permit from Stockholm's environmental authority — we handle the application for you."
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "Which heat pump is best for Stockholm homes?",
            "answer": "For houses with direct electric heating, air-to-air is the quickest win. For water-based heating systems (radiators or underfloor), air-to-water or ground source gives the highest savings. Our technician will recommend the right solution during the home visit."
          }
        },
        "faq-4": {
          "type": "faq_item",
          "settings": {
            "question": "How long does installation take?",
            "answer": "Air-to-air installation is usually completed in one day. Air-to-water takes 1–2 days. Ground source drilling and installation typically takes 3–5 days depending on ground conditions."
          }
        },
        "faq-5": {
          "type": "faq_item",
          "settings": {
            "question": "How much can I save on electricity?",
            "answer": "Most Stockholm customers reduce their heating costs by 40–70%. A typical villa in Stockholm can save around 38,400 SEK per year after switching from direct electric heating to a ground source heat pump."
          }
        }
