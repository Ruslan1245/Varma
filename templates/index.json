    "varma-faq": {
      "type": "varma-faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "What does a heat pump installation cost in Stockholm?",
            "answer": "A complete air heat pump installation for a typical house of 120–150 m² typically costs 85,000–140,000 SEK including equipment and labor. Geothermal is higher at 180,000–280,000 SEK, but delivers significantly greater savings over time. Varma provides a fixed quote after a free home visit."
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "How long does the installation take?",
            "answer": "An air heat pump is normally installed in 1–2 days. Geothermal takes 3–5 days including drilling. We plan the work to minimise disruption to your home."
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "What warranty do you offer?",
            "answer": "We provide a 10-year warranty on installation work and honor the manufacturer's product warranty, typically 5–7 years. All our installers are certified and F-gas licensed."
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "How quickly can you respond to emergencies?",
            "answer": "We have technicians stationed throughout Greater Stockholm and guarantee response within 2 hours around the clock, every day of the year – including weekends and public holidays."
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "Are there grants or deductions available for heat pumps in Sweden?",
            "answer": "Yes. As a homeowner you can use the green deduction (gröna avdraget), which covers 50% of the labour cost, up to 50,000 kr per person per year. Varma handles all the administration for you."
          }
        }
      },
